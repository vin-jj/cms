{"content":[{"attrs":{"level":1},"content":[{"text":"シャドーAIリスクの全貌｜経営を脅かす「見えないAI」にCxOはどう立ち向かうか","type":"text"}],"type":"heading"},{"attrs":{"level":2},"content":[{"text":"結論：シャドーAIは経営リスクそのものである","type":"text"}],"type":"heading"},{"content":[{"marks":[{"type":"bold"}],"text":"シャドーAIは、もはやIT部門だけの問題ではありません。情報漏洩、コンプライアンス違反、知的財産の流出など、経営の根幹を揺るがすビジネスリスクです。","type":"text"}],"type":"paragraph"},{"content":[{"text":"IBMが2025年に発表した「Cost of a Data Breach Report 2025」によると、シャドーAIに起因するデータ侵害コストは平均463万ドルに達し、通常の侵害よりも約67万ドル（約1億円）高くなることが明らかになりました。さらに、AI関連のセキュリティインシデントを経験した組織の97%が、適切なAIアクセス制御を欠いていたという事実も判明しています。","type":"text"}],"type":"paragraph"},{"content":[{"text":"本記事では、CxO層が把握すべきシャドーAIの実態とリスク、そして明日から実行可能な具体的対策を、最新の調査データとともに体系的に解説します。","type":"text"}],"type":"paragraph"},{"type":"horizontalRule"},{"attrs":{"level":2},"content":[{"text":"シャドーAIとは何か？―シャドーITとの違いと急増の背景","type":"text"}],"type":"heading"},{"content":[{"text":"シャドーAIとは、","type":"text"},{"marks":[{"type":"bold"}],"text":"企業のIT部門や経営層の承認を得ずに、従業員が個人の判断で業務に利用するAIツール","type":"text"},{"text":"を指します。ChatGPT、Claude、Gemini、Midjourney、AI文字起こしツールなど、ブラウザひとつで利用できるサービスが主な対象です。","type":"text"}],"type":"paragraph"},{"attrs":{"level":3},"content":[{"text":"シャドーITとの決定的な違い","type":"text"}],"type":"heading"},{"content":[{"text":"従来の「シャドーIT」は、許可されていないITツールやクラウドサービスを業務で使用する問題でした。シャドーAIはその概念がAI時代に拡張したものですが、","type":"text"},{"marks":[{"type":"bold"}],"text":"決定的に異なる点","type":"text"},{"text":"があります。","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"content":[{"text":"項目","type":"text"}],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"シャドーAI","type":"text"}],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"シャドーIT","type":"text"}],"type":"paragraph"}],"type":"tableHeader"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"主なリスク","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"入力データがAIの学習データとして使用される可能性","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"未許可クラウドへのデータ保存・不正アクセス","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"データ回収の可否","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"一度学習されると完全な削除が極めて困難","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"サービス停止・データ削除で対応可能な場合が多い","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"影響範囲","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"機密情報が第三者の回答に反映される恐れ","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"主に自社内のセキュリティ脆弱性","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"}],"type":"table"},{"attrs":{"level":3},"content":[{"text":"なぜシャドーAIは急増しているのか","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"AIツールの爆発的普及","type":"text"},{"text":"：ブラウザさえあれば誰でも高性能AIを無料で利用可能","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"企業側のガイドライン整備の遅れ","type":"text"},{"text":"：総務省の令和7年版「情報通信白書」によると、中小企業では生成AIの活用方針を「明確に定めていない」との回答が多数。エルテスの調査でも、利用規則が「ない」と回答した企業は45%に上り、4社に1社が方針未策定","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"従業員のリスク認識不足","type":"text"},{"text":"：便利さが先行し、情報漏洩リスクへの理解が追いついていない","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"業務効率化への強いニーズ","type":"text"},{"text":"：議事録作成、メール下書き、データ分析など、即座に効果を実感できるため止められない","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"Netskopeの2026年版レポートによれば、企業における生成AI利用者の","type":"text"},{"marks":[{"type":"bold"}],"text":"47%が個人アカウントで業務にAIを使用","type":"text"},{"text":"しており、セキュリティチームはこれらの利用状況をほとんど把握できていません。","type":"text"}],"type":"paragraph"},{"type":"horizontalRule"},{"attrs":{"level":2},"content":[{"text":"数字で見るシャドーAIの衝撃的な現状","type":"text"}],"type":"heading"},{"content":[{"text":"シャドーAIの脅威がいかに深刻かを、最新の調査データで確認しましょう。","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"content":[{"text":"指標","type":"text"}],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"数値","type":"text"}],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"出典","type":"text"}],"type":"paragraph"}],"type":"tableHeader"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"シャドーAI侵害の平均コスト","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"463万ドル（通常比+67万ドル）","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"[1]","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"AI関連侵害で適切なアクセス制御を欠く組織","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"97%","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"[1]","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"AIガバナンスポリシーが未整備 / 策定中の組織","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"63%","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"[1]","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"IT未承認でAIツールを運用している割合","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"65%","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"[2]","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"個人アカウントでAIを業務利用する従業員","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"47%","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"[3]","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"企業のAI利用頻度の増加（過去1年）","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"約4.6倍","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"[4]","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"AIへの入力で最多の機密データ種別","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"ソースコード（18.7%）","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"[4]","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"データポリシー違反件数（前年比）","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"2倍以上に急増","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"[3]","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"生成AI利用者のうちシャドーAI該当","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"約5人に1人（20%）","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"[5]","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"AIガバナンス協会調査：全回答企業の生成AI利用率","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"100%（37社/37社）","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"[6]","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"}],"type":"table"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"出典一覧","type":"text"}],"type":"paragraph"},{"content":[{"text":"- [1] IBM: ","type":"text"},{"marks":[{"attrs":{"href":"https://www.ibm.com/reports/data-breach"},"type":"link"}],"text":"Cost of a Data Breach Report 2025","type":"text"}],"type":"paragraph"},{"content":[{"text":"- [2] Knostic: ","type":"text"},{"marks":[{"attrs":{"href":"https://www.knostic.ai/blog/shadow-ai"},"type":"link"}],"text":"Detect and Control: Shadow AI in the Enterprise","type":"text"}],"type":"paragraph"},{"content":[{"text":"- [3] Netskope: ","type":"text"},{"marks":[{"attrs":{"href":"https://www.netskope.com/resources/cloud-and-threat-reports/cloud-and-threat-report-shadow-ai-and-agentic-ai-2025"},"type":"link"}],"text":"Cloud and Threat Report: Shadow AI and Agentic AI 2025","type":"text"}],"type":"paragraph"},{"content":[{"text":"- [4] Cyberhaven: ","type":"text"},{"marks":[{"attrs":{"href":"https://www.cyberhaven.com/resources/report/2025-ai-adoption-risk-report"},"type":"link"}],"text":"2025 AI Adoption and Risk Report","type":"text"}],"type":"paragraph"},{"content":[{"text":"- [5] エルテス: ","type":"text"},{"marks":[{"attrs":{"href":"https://eltes.co.jp/news/20260119"},"type":"link"}],"text":"生成AI利用者の約5人に1人が「シャドーAI」リスク","type":"text"}],"type":"paragraph"},{"content":[{"text":"- [6] AIガバナンス協会: ","type":"text"},{"marks":[{"attrs":{"href":"https://cdn.prod.website-files.com/66e98b87b115812d1af8fc1c/697b920ea54102675b77e926_itsunomanika%20report.pdf"},"type":"link"}],"text":"いつの間にか AIのリスク実態調査 ～シャドーAI等の管理と捕捉 課題とプラクティス～","type":"text"}],"type":"paragraph"}],"type":"blockquote"},{"content":[{"text":"これらの数字が示すのは明確です。","type":"text"},{"marks":[{"type":"bold"}],"text":"AIの利用拡大とセキュリティ対策の間に、巨大なギャップが生まれている","type":"text"},{"text":"ということです。","type":"text"}],"type":"paragraph"},{"type":"horizontalRule"},{"attrs":{"level":2},"content":[{"text":"シャドーAIが企業にもたらす6大リスク","type":"text"}],"type":"heading"},{"attrs":{"level":3},"content":[{"text":"1. 機密情報・個人情報の漏洩","type":"text"}],"type":"heading"},{"content":[{"text":"シャドーAI最大のリスクです。従業員が生成AIに業務データを入力すると、その情報がクラウド上で保存・処理され、AIの学習データとして利用される可能性があります。一度AIサービスに入力された情報を完全に削除することは極めて困難です。","type":"text"}],"type":"paragraph"},{"content":[{"text":"Cyberhavenの調査では、AIに入力される機密データの内訳として","type":"text"},{"marks":[{"type":"bold"}],"text":"ソースコードが18.7%","type":"text"},{"text":"、","type":"text"},{"marks":[{"type":"bold"}],"text":"財務資料などの機密情報が17.1%","type":"text"},{"text":"を占めています。IBMの調査でも、シャドーAIインシデントの","type":"text"},{"marks":[{"type":"bold"}],"text":"65%で個人識別情報（PII）が","type":"text"},{"text":"、","type":"text"},{"marks":[{"type":"bold"}],"text":"40%で知的財産が","type":"text"},{"text":"漏洩しています。","type":"text"}],"type":"paragraph"},{"attrs":{"level":3},"content":[{"text":"2. コンプライアンス違反・法的リスク","type":"text"}],"type":"heading"},{"content":[{"text":"顧客情報をAIに入力する行為は、","type":"text"},{"marks":[{"type":"bold"}],"text":"個人情報保護法やGDPRへの抵触","type":"text"},{"text":"につながります。金融業界では金融分野における個人情報保護ガイドライン、医療業界ではHIPAA規制、製造業では不正競争防止法など、業界固有の規制違反リスクも無視できません。違反が発覚すれば、多額の罰金と社会的信用の喪失が待っています。","type":"text"}],"type":"paragraph"},{"attrs":{"level":3},"content":[{"text":"3. 秘密保持契約（NDA）違反と知的財産リスク","type":"text"}],"type":"heading"},{"content":[{"text":"取引先との","type":"text"},{"marks":[{"type":"bold"}],"text":"秘密保持契約（NDA）違反","type":"text"},{"text":"は、シャドーAIならではの深刻な問題です。顧客から預かった情報を許可なくAIツールに入力する行為は、NDA違反と見なされるケースが想定されます。また、AI生成コンテンツが既存の著作物と類似している場合、意図しない","type":"text"},{"marks":[{"type":"bold"}],"text":"著作権侵害","type":"text"},{"text":"が発生する可能性もあります。さらに、自社の重要な知的財産がAIの学習データに含まれることで、競合他社に情報が流出するリスクも考えられます。","type":"text"}],"type":"paragraph"},{"attrs":{"level":3},"content":[{"text":"4. ハルシネーションによる業務品質・ブランドへの悪影響","type":"text"}],"type":"heading"},{"content":[{"text":"生成AIの「","type":"text"},{"marks":[{"type":"bold"}],"text":"ハルシネーション","type":"text"},{"text":"（事実に基づかない情報の生成）」は、誤ったデータに基づく意思決定、顧客への誤情報提供、成果物の品質低下を招きます。特に経営判断に関わる場面で発生すれば、巨額の損失につながりかねません。各部門が異なるAIツールを無秩序に使うことで、サービス品質のばらつきも発生します。","type":"text"}],"type":"paragraph"},{"attrs":{"level":3},"content":[{"text":"5. セキュリティリスクの拡大","type":"text"}],"type":"heading"},{"content":[{"text":"IT部門の管理外にあるAIツールは、企業のセキュリティ対策の「死角」となります。脆弱性を持つAIサービスを経由したサイバー攻撃、プロンプトインジェクションによる情報窃取、アカウント乗っ取りなど、従来のシャドーITを超える複合的な脅威を生み出します。2026年2月にはOktaが未承認AIエージェントを検出する「Agent Discovery」機能を発表するなど、シャドーAIの可視化と統制は業界全体の急務となっています。","type":"text"}],"type":"paragraph"},{"attrs":{"level":3},"content":[{"text":"6. インシデント対応の困難化・原因究明の遅延","type":"text"}],"type":"heading"},{"content":[{"text":"シャドーAIの利用実態が「ブラックボックス化」している状態では、問題発生時の","type":"text"},{"marks":[{"type":"bold"}],"text":"原因究明や被害範囲の特定に多大な時間","type":"text"},{"text":"を要します。IBMの調査によれば、シャドーAIに起因する侵害の検知・封じ込めには、通常より約1週間長くかかります。「誰が」「どのツールで」「何を入力したか」を特定できないことは、企業の危機管理体制そのものを機能不全に陥らせます。初動対応の遅れは被害の拡大を招き、二次被害・三次被害へと連鎖するリスクがあります。","type":"text"}],"type":"paragraph"},{"type":"horizontalRule"},{"attrs":{"level":2},"content":[{"text":"実際に起きた情報漏洩事例―サムスン電子のケース","type":"text"}],"type":"heading"},{"content":[{"text":"シャドーAIによる情報漏洩は、すでに現実のものとなっています。","type":"text"}],"type":"paragraph"},{"content":[{"text":"韓国サムスン電子で2023年、複数の従業員がChatGPTに機密情報を入力する事案が発生しました。","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"事例1","type":"text"},{"text":"：半導体設備の測定データベース用ソフトのエラー解決のため、","type":"text"},{"marks":[{"type":"bold"}],"text":"ソースコード","type":"text"},{"text":"をChatGPTに入力","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"事例2","type":"text"},{"text":"：半導体の歩留まり・不良設備を把握するプログラムの","type":"text"},{"marks":[{"type":"bold"}],"text":"コード最適化","type":"text"},{"text":"にChatGPTを利用","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"事例3","type":"text"},{"text":"：社内会議の音声データを","type":"text"},{"marks":[{"type":"bold"}],"text":"文字起こし","type":"text"},{"text":"し、","type":"text"},{"marks":[{"type":"bold"}],"text":"議事録作成","type":"text"},{"text":"のためにChatGPTに入力","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"いずれも「業務効率化」という純粋な動機からの行動でした。しかし同社はその後、社用デバイスでの生成AI利用を禁止し、AIへの1回あたりのアップロード容量を制限。違反者には解雇もあり得ると警告する厳格な対応を取りました。","type":"text"}],"type":"paragraph"},{"content":[{"text":"この事例は、","type":"text"},{"marks":[{"type":"bold"}],"text":"悪意のない従業員の行動が、企業の存続を脅かす重大なセキュリティリスクになり得る","type":"text"},{"text":"ことを示しています。","type":"text"}],"type":"paragraph"},{"type":"horizontalRule"},{"attrs":{"level":2},"content":[{"text":"部門別リスクシナリオ―営業・人事・経営企画","type":"text"}],"type":"heading"},{"content":[{"text":"シャドーAIのリスクは、すべての部門に潜んでいます。","type":"text"}],"type":"paragraph"},{"attrs":{"level":3},"content":[{"text":"営業部門","type":"text"}],"type":"heading"},{"content":[{"text":"営業担当者が、過去の商談情報・競合情報・価格戦略をAIに入力してアプローチメールを作成。これらの機密情報が外部サーバーに保存され、学習データとして利用されるリスクが発生します。","type":"text"}],"type":"paragraph"},{"attrs":{"level":3},"content":[{"text":"人事部門","type":"text"}],"type":"heading"},{"content":[{"text":"人事担当者が採用面接の質問作成時に、「現在のチームは○○技術の経験者が不足している」といった組織の弱点に関する内部情報を入力。競合他社が自社の課題を把握し、人材引き抜きに活用する可能性があります。","type":"text"}],"type":"paragraph"},{"attrs":{"level":3},"content":[{"text":"経営企画部門","type":"text"}],"type":"heading"},{"content":[{"text":"M&A候補企業の評価レポート作成で、非公開の財務データや買収の法的リスク、交渉中の価格情報をAIに入力。機密情報の流出は、競合他社に戦略的優位性を与え、交渉で著しく不利な立場に追い込まれる事態を招きます。","type":"text"}],"type":"paragraph"},{"type":"horizontalRule"},{"attrs":{"level":2},"content":[{"text":"「禁止」ではなく「管理」が正解―5つの具体的対策","type":"text"}],"type":"heading"},{"content":[{"text":"AIツールの利用を一律に禁止することは、現実的ではありません。","type":"text"},{"marks":[{"type":"bold"}],"text":"禁止はかえってシャドーAIを助長し","type":"text"},{"text":"、利用がさらに見えにくいアンダーグラウンドの形で進行します。求められるのは、","type":"text"},{"marks":[{"type":"bold"}],"text":"「安全に使える環境」を企業が主導的に整備すること","type":"text"},{"text":"です。","type":"text"}],"type":"paragraph"},{"attrs":{"level":3},"content":[{"text":"対策1：AIガバナンス体制を整備する","type":"text"}],"type":"heading"},{"content":[{"text":"AI利用に関する承認プロセス、責任の所在、リスク評価の仕組みを明確化します。AIガバナンス委員会などの専門組織を設置し、ポリシーの見直しや新リスクの洗い出しを定期的に実施することで、形骸化を防ぎます。AIガバナンス協会（AIGA）が2026年1月に公表した「いつの間にかAI実態調査」でも、AIユースケースの捕捉（シャドーAIの防止）が先進企業の共通課題として挙げられています。","type":"text"}],"type":"paragraph"},{"content":[{"marks":[{"type":"bold"}],"text":"実践ポイント","type":"text"},{"text":"：","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"AI利用の承認プロセスをフローチャートで可視化","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"責任者（CAIO等）を任命し、経営会議で定期報告","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"四半期ごとのリスクアセスメント実施","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"EU AI法（2026年8月本格適用）への対応も視野に","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":3},"content":[{"text":"対策2：AI利用ガイドライン・ポリシーを策定・周知する","type":"text"}],"type":"heading"},{"content":[{"text":"全従業員が守るべき明確なルールを定めます。「何を入力してはいけないか」だけでなく、「どうすれば安全に使えるか」を具体的に示すことが重要です。","type":"text"}],"type":"paragraph"},{"content":[{"marks":[{"type":"bold"}],"text":"入力禁止情報の例","type":"text"},{"text":"：","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"顧客の個人情報（氏名、住所、購買履歴等）","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"未公開の財務情報（売上データ、M&A情報等）","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"開発中の製品仕様（ソースコード、特許出願前の技術情報等）","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"取引先との契約内容（価格情報、NDA保護情報等）","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":3},"content":[{"text":"対策3：セキュアなAIツールを公式導入し代替手段を提供する","type":"text"}],"type":"heading"},{"content":[{"text":"シャドーAI対策の最も効果的な方法は、","type":"text"},{"marks":[{"type":"bold"}],"text":"企業が安全性を確認したAIツールを公式に提供する","type":"text"},{"text":"ことです。従業員の「AIを使って業務を効率化したい」というニーズに応えつつ、リスクを組織の管理下に置くことが可能になります。","type":"text"}],"type":"paragraph"},{"content":[{"marks":[{"type":"bold"}],"text":"選定基準","type":"text"},{"text":"：","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"データの学習利用がオプトアウト / 完全不使用であること","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"ISMS / ISMSクラウドセキュリティ認証の取得","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"管理者による利用ログの閲覧・監査機能","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"SSO / MFAなどアクセス制御機能","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"自社専用プライベート環境でのAI運用も選択肢に","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":3},"content":[{"text":"対策4：従業員教育でリテラシーを向上させる","type":"text"}],"type":"heading"},{"content":[{"text":"ルールを策定しても、従業員の理解と意識が伴わなければ効果は限定的です。シャドーAIのリスクを具体的な事例で伝え、安全な利用方法を継続的に教育します。エルテスの調査では、利用規則がある企業ほどシャドーAI該当率が低いことが示されており、ポリシーと教育の相乗効果が確認されています。","type":"text"}],"type":"paragraph"},{"content":[{"marks":[{"type":"bold"}],"text":"教育プログラム設計のポイント","type":"text"},{"text":"：","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"全社一律研修＋部門別の専門研修の二段構え","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"サムスン電子など実際の漏洩事例を教材として活用","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"効果的なプロンプト作成スキルも合わせて指導","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"eラーニングと定期勉強会の組み合わせで継続性を確保","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":3},"content":[{"text":"対策5：技術的な監視・検知体制を強化する","type":"text"}],"type":"heading"},{"content":[{"text":"ポリシーと教育だけでは、すべてのシャドーAI利用を把握することはできません。","type":"text"},{"marks":[{"type":"bold"}],"text":"ログ監視による利用状況の可視化","type":"text"},{"text":"と、技術的な多層防御が不可欠です。","type":"text"}],"type":"paragraph"},{"content":[{"marks":[{"type":"bold"}],"text":"技術的対策の柱","type":"text"},{"text":"：","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"CASB","type":"text"},{"text":"（Cloud Access Security Broker）によるクラウドAIサービスの利用監視","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"DLP","type":"text"},{"text":"（Data Loss Prevention）ツールによる機密情報のアップロード制御","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"ネットワークトラフィック分析による未承認AIサービスへのアクセス検知","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"プロンプトへの機密情報混入の自動検知","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Webフィルタリングによる未承認AIサービスへのアクセス制限","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"ブラウザ拡張機能のカタログ化・管理","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"異常検知システムによる大量データ送信パターンの自動検出","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"type":"horizontalRule"},{"attrs":{"level":2},"content":[{"text":"対策アプローチ比較表","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"content":[{"text":"対策カテゴリ","type":"text"}],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"主な手法","type":"text"}],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"効果","type":"text"}],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"導入難易度","type":"text"}],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"優先度","type":"text"}],"type":"paragraph"}],"type":"tableHeader"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"ガバナンス整備","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"AI利用承認プロセス / ガバナンス委員会設置 / CAIO任命","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"組織的なリスク統制の基盤構築","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"中","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"★★★★★","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"ポリシー策定","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"利用ガイドライン策定 / 承認ツールリスト作成 / 入力禁止情報の明文化","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"従業員の行動指針を明確化","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"低","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"★★★★★","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"セキュアツール導入","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"企業向け生成AI環境の公式提供 / プライベートAI構築","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"シャドーAI利用の根本原因を解消","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"中〜高","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"★★★★☆","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"従業員教育","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"全社研修 / 部門別研修 / eラーニング / 事例ベース学習","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"リスク意識とリテラシー向上","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"低〜中","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"★★★★☆","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"技術的監視","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"CASB / DLP / ログ監視 / Webフィルタリング / 異常検知","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"未承認利用の検知と機密データ流出防止","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"高","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"★★★★☆","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"}],"type":"table"},{"type":"horizontalRule"},{"attrs":{"level":2},"content":[{"text":"まとめと経営層への提言","type":"text"}],"type":"heading"},{"content":[{"text":"シャドーAIは、従業員の悪意ではなく「業務をもっと効率化したい」という善意から生まれる問題です。だからこそ、単純な禁止では解決しません。","type":"text"}],"type":"paragraph"},{"attrs":{"level":3},"content":[{"text":"経営層が押さえるべき3つのポイント","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"シャドーAIは「ITの問題」ではなく「経営リスク」","type":"text"},{"text":"：侵害コスト平均463万ドル、97%の組織でアクセス制御が欠如。情報漏洩、NDA違反、著作権侵害、コンプライアンス違反など、経営基盤を揺るがすリスクが複合的に存在します","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"「禁止」ではなく「安全な代替手段の提供」","type":"text"},{"text":"：従業員のニーズに応えながらリスクを管理するアプローチが最も効果的です。禁止はアンダーグラウンド化を招き、インシデント対応をさらに困難にします","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"AIガバナンスと技術的監視の両輪で対策を推進","type":"text"},{"text":"：利用ガイドライン策定・従業員教育とDLP/CASB/ログ監視を組み合わせた多層防御が不可欠です","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":3},"content":[{"text":"今すぐ実行すべきアクション","type":"text"}],"type":"heading"},{"content":[{"marks":[{"type":"bold"}],"text":"今日","type":"text"},{"text":"：","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"自社のAI利用ガイドライン・ポリシーの有無を確認する","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"IT部門と連携し、従業員のAIツール利用状況の概況を把握する","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"marks":[{"type":"bold"}],"text":"今週中","type":"text"},{"text":"：","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"経営会議でシャドーAIリスクをアジェンダに追加する","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"承認済みAIツールリストの作成に着手する","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"marks":[{"type":"bold"}],"text":"今月中","type":"text"},{"text":"：","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"AIガバナンス体制の設計と責任者（CAIO等）の任命","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"セキュアな企業向けAI環境の選定・PoC開始","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"全従業員向けのAIリテラシー研修の企画","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"DLP/CASB等の技術的監視体制の導入検討","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"type":"horizontalRule"},{"content":[{"text":"シャドーAIの対策は、「コスト」ではなく「投資」です。安全なAI活用環境を整えることは、従業員の生産性向上と企業価値の保全を同時に実現する、経営戦略そのものといえるでしょう。","type":"text"}],"type":"paragraph"},{"type":"horizontalRule"},{"content":[{"marks":[{"type":"bold"}],"text":"【参考資料】","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"IBM: ","type":"text"},{"marks":[{"attrs":{"href":"https://www.ibm.com/reports/data-breach"},"type":"link"}],"text":"Cost of a Data Breach Report 2025","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Netskope: ","type":"text"},{"marks":[{"attrs":{"href":"https://www.netskope.com/resources/cloud-and-threat-reports/cloud-and-threat-report-shadow-ai-and-agentic-ai-2025"},"type":"link"}],"text":"Cloud and Threat Report: Shadow AI and Agentic AI 2025","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Cyberhaven: ","type":"text"},{"marks":[{"attrs":{"href":"https://www.cyberhaven.com/resources/report/2025-ai-adoption-risk-report"},"type":"link"}],"text":"2025 AI Adoption and Risk Report","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"総務省: ","type":"text"},{"marks":[{"attrs":{"href":"https://www.soumu.go.jp/johotsusintokei/whitepaper/ja/r07/html/nd112220.html"},"type":"link"}],"text":"令和7年版 情報通信白書","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Knostic: ","type":"text"},{"marks":[{"attrs":{"href":"https://www.knostic.ai/blog/shadow-ai"},"type":"link"}],"text":"Detect and Control: Shadow AI in the Enterprise","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"エルテス: ","type":"text"},{"marks":[{"attrs":{"href":"https://eltes.co.jp/news/20260119"},"type":"link"}],"text":"生成AI利用者の約5人に1人が「シャドーAI」リスク","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"AIガバナンス協会: ","type":"text"},{"marks":[{"attrs":{"href":"https://cdn.prod.website-files.com/66e98b87b115812d1af8fc1c/697b920ea54102675b77e926_itsunomanika%20report.pdf"},"type":"link"}],"text":"いつの間にか AIのリスク実態調査 ～シャドーAI等の管理と捕捉 課題とプラクティス～","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Okta: ","type":"text"},{"marks":[{"attrs":{"href":"https://www.okta.com/ja-jp/newsroom/press-releases/okta-secures-the-agentic-enterprise-with-new-tools-for-discovering-and-mitigating-shadow-ai-risks/"},"type":"link"}],"text":"シャドーAIエージェントのリスクを可視化・軽減する新機能 Agent Discovery を発表","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"}],"type":"doc"}