leCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"<strong>2</strong>","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Limited Production Validation","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Completed incident-response drill cycle","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"<strong>3</strong>","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Institutionalization","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Enterprise policy + management approval","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"}],"type":"table"},{"type":"horizontalRule"},{"attrs":{"level":1},"content":[{"text":"Appendix: Glossary for AI-Agent Guardrail Design","type":"text"}],"type":"heading"},{"attrs":{"level":2},"content":[{"text":"AI-Agent Terms","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"AI Agent","type":"text"},{"text":": AI system that autonomously decides and executes actions","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Agentic AI","type":"text"},{"text":": AI that sets goals, plans, and acts autonomously","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"MCP (Model Context Protocol)","type":"text"},{"text":": standard protocol for connecting models to tools/data","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Computer Use","type":"text"},{"text":": AI ability to operate applications via keyboard/mouse-like actions","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Shadow AI","type":"text"},{"text":": unapproved AI tools used outside governance","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Hallucination","type":"text"},{"text":": plausible but incorrect AI output","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":2},"content":[{"text":"Guardrail Terms","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Guardrails","type":"text"},{"text":": control boundaries and rules for safe AI operations","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Least Privilege","type":"text"},{"text":": grant only minimum required access","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"RACI","type":"text"},{"text":": Responsible / Accountable / Consulted / Informed","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Kill Switch","type":"text"},{"text":": emergency stop mechanism for anomalies","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Fail-safe","type":"text"},{"text":": design that defaults to safe state during failure","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"RCA (Root Cause Analysis)","type":"text"},{"text":": analysis of underlying incident causes","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":2},"content":[{"text":"Security & Compliance Terms","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Supply Chain Risk","type":"text"},{"text":": risk introduced via external software/libraries/tools","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"RCE (Remote Code Execution)","type":"text"},{"text":": vulnerability enabling remote arbitrary execution","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"API Key","type":"text"},{"text":": authentication credential for external service access","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Sandbox","type":"text"},{"text":": isolated execution environment","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"CAIO (Chief AI Officer)","type":"text"},{"text":": executive owner of enterprise AI governance","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"NIST AI RMF","type":"text"},{"text":": AI risk management framework (Govern/Map/Measure/Manage)","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"type":"horizontalRule"},{"attrs":{"level":1},"content":[{"text":"Closing: From Design to Implementation, From Implementation to Culture","type":"text"}],"type":"heading"},{"content":[{"text":"Across both parts:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"Part 1 covered why guardrails are necessary and how to design them","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Part 2 provided concrete cases, a checklist, and a 90-day roadmap","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"Guardrails are not brakes on AI innovation. They are the ","type":"text"},{"marks":[{"type":"bold"}],"text":"foundation for scaling AI safely","type":"text"},{"text":".","type":"text"}],"type":"paragraph"},{"content":[{"text":"If you can stop AI, you can trust it.","type":"text"},{"type":"hardBreak"},{"text":"If you ca