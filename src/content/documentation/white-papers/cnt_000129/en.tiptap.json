{"content":[{"attrs":{"alt":"Guardrail Design in the AI Agent Era (Part 2: Practice & Implementation)","caption":"","src":"/documentation/white-papers/wp-thumb-29.webp"},"type":"image"},{"attrs":{"level":1},"content":[{"text":"Guardrail Design in the AI Agent Era: Case Studies, Checklist, and 90-Day Roadmap","type":"text"}],"type":"heading"},{"content":[{"text":"📖 Estimated reading time: ~15 minutes","type":"text"}],"type":"paragraph"},{"type":"horizontalRule"},{"attrs":{"level":2},"content":[{"text":"Key Takeaway (1-Minute Read)","type":"text"}],"type":"heading"},{"content":[{"text":"In ","type":"text"},{"marks":[{"attrs":{"href":"/features/documentation/white-paper/28/ai-agent-guardrails-governance-2026"},"type":"link"}],"text":"Part 1","type":"text"},{"text":", we organized AI-agent guardrails into four elements: Permission, Approval, Audit Trail, and Kill Switch.","type":"text"}],"type":"paragraph"},{"content":[{"text":"Part 2 turns knowledge into execution.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"content":[{"text":"Part 2 Structure","type":"text"}],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"What You Get","type":"text"}],"type":"paragraph"}],"type":"tableHeader"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"<strong>Chapter 4: 3 Case Studies</strong>","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Concrete understanding of how the four elements work in real cases: PC-operation agents, development AI vulnerabilities, autonomous 5G operations","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"<strong>Chapter 5: Reusable Checklist</strong>","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"A one-page diagnostic sheet you can bring to tomorrow’s meeting","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"<strong>Chapter 6: 90-Day Roadmap</strong>","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Practical timeline from PoC to limited rollout to expansion","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"<strong>Appendix: Glossary</strong>","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"A shared language so non-technical executives can actively participate","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"}],"type":"table"},{"content":[{"text":"MIT Sloan Management Review (2025) found that ","type":"text"},{"marks":[{"type":"bold"}],"text":"95% of GenAI pilots fail to prove P&L impact","type":"text"},{"text":". S&P Global also reported ","type":"text"},{"marks":[{"type":"bold"}],"text":"42% of AI initiatives were canceled in 2025","type":"text"},{"text":" (up 25 percentage points YoY). The core failure driver is not technology capability, but governance design.","type":"text"}],"type":"paragraph"},{"type":"horizontalRule"},{"attrs":{"level":1},"content":[{"text":"Chapter 4. Case Studies: How the Four Elements Work in Reality","type":"text"}],"type":"heading"},{"attrs":{"level":2},"content":[{"text":"Case 1: Privilege Escalation Risk in PC-Operation Agents — Lessons from Claude Desktop Extensions (DXT)","type":"text"}],"type":"heading"},{"attrs":{"level":3},"content":[{"text":"What Happened","type":"text"}],"type":"heading"},{"content":[{"text":"In February 2026, LayerX disclosed serious design vulnerabilities in Anthropic’s Claude Desktop Extensions (DXT), which enable Claude to directly operate local PC applications.","type":"text"}],"type":"paragraph"},{"content":[{"text":"The core issue: ","type":"text"},{"marks":[{"type":"bold"}],"text":"DXT operated with full system privileges without sandboxing","type":"text"},{"text":" (source: ","type":"text"},{"marks":[{"attrs":{"href":"https://www.csoonline.com/article/4129820/anthropics-dxt-poses-critical-rce-vulnerability-by-running-with-full-system-privileges.html"},"type":"link"}],"text":"CSO Online, 2026","type":"text"},{"text":").","type":"text"}],"type":"paragraph"},{"content":[{"text":"Risk pattern:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"Low-risk connectors (e.g., calendar reads) and high-risk local execution could be chained autonomously.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Prompt injection via external data (e.g., malicious calendar text) could trigger arbitrary code execution.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"With broad extension usage, blast radius was significant.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":3},"content":[{"text":"Four-Element Analysis","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"content":[{"text":"Element","type":"text"}],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"Gap in This Case","type":"text"}],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"Required Design","type":"text"}],"type":"paragraph"}],"type":"tableHeader"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"<strong>1) Permission</strong>","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Full-system privilege, no scope/ceiling limits","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Action-level least privilege, e.g., calendar read allowed, local write blocked","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"<strong>2) Approval</strong>","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Low-risk to high-risk chain executed with no human approval","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Require approval when risk level escalates across operation chains","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"<strong>3) Audit Trail</strong>","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Opaque extension-call sequence and rationale","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Log full call chain and rationale at each step","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"<strong>4) Kill Switch</strong>","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"No mechanism to detect/stop abnormal chains","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Set depth/blast thresholds; auto-pause and notify on exceedance","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"}],"type":"table"},{"attrs":{"level":3},"content":[{"text":"Management Implication","type":"text"}],"type":"heading"},{"content":[{"text":"For PC-operation agents, governance must include not only what each action can do, but ","type":"text"},{"marks":[{"type":"bold"}],"text":"which actions can be combined","type":"text"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"horizontalRule"},{"attrs":{"level":2},"content":[{"text":"Case 2: Supply Chain Risk in Development AI — What Claude Code Vulnerabilities Revealed","type":"text"}],"type":"heading"},{"attrs":{"level":3},"content":[{"text":"What Happened","type":"text"}],"type":"heading"},{"content":[{"text":"On February 25, 2026, Check Point Research disclosed multiple serious vulnerabilities in Anthropic’s AI coding tool Claude Code (source: ","type":"text"},{"marks":[{"attrs":{"href":"https://research.checkpoint.com/2026/rce-and-api-token-exfiltration-through-claude-code-project-files-cve-2025-59536/"},"type":"link"}],"text":"Check Point Research, 2026","type":"text"},{"text":").","type":"text"}],"type":"paragraph"},{"content":[{"text":"Key point: attacks could trigger simply by cloning and opening a malicious repository.","type":"text"}],"type":"paragraph"},{"content":[{"text":"Notable issues included:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"CVE-2025-59536","type":"text"},{"text":": command execution via malicious hooks/MCP settings","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"CVE-2026-21852","type":"text"},{"text":": API-token exfiltration by redirecting API traffic through manipulated environment settings","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"GHSA-ph6w","type":"text"},{"text":": hidden shell execution via hooks abuse","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"This highlighted a new AI supply-chain risk: “passive” configuration files can become active execution paths.","type":"text"}],"type":"paragraph"},{"attrs":{"level":3},"content":[{"text":"Four-Element Analysis","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"content":[{"text":"Element","type":"text"}],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"Gap in This Case","type":"text"}],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"Required Design","type":"text"}],"type":"paragraph"}],"type":"tableHeader"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"<strong>1) Permission</strong>","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Config files implicitly allowed execution authority","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Strictly separate config authority from execution authority","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"<strong>2) Approval</strong>","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Outbound communication started before trust confirmation","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Block network activity before user approval by default","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"<strong>3) Audit Trail</strong>","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Difficult to trace what config triggered what command","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Log full chain: config load -> command execution -> destination changes","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"<strong>4) Kill Switch</strong>","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"No auto-block for suspicious API destination switch","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Whitelist destinations, auto-block unknown endpoints, alert admins","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"}],"type":"table"},{"attrs":{"level":3},"content":[{"text":"Management Implication","type":"text"}],"type":"heading"},{"content":[{"text":"AI tool vulnerabilities are not individual developer problems; they are organization-wide supply-chain risks.","type":"text"}],"type":"paragraph"},{"type":"horizontalRule"},{"attrs":{"level":2},"content":[{"text":"Case 3: Autonomous Critical Infrastructure Operations — Nokia x AWS Agentic AI Network Slicing","type":"text"}],"type":"heading"},{"attrs":{"level":3},"content":[{"text":"What Happened","type":"text"}],"type":"heading"},{"content":[{"text":"In February 2026, Nokia and AWS announced a live proof-of-concept of agentic AI for 5G-Advanced network slicing, with early pilot partners including du (UAE) and Orange (France) (source: ","type":"text"},{"marks":[{"attrs":{"href":"https://www.sdxcentral.com/news/nokia-and-aws-let-agentic-ai-take-the-wheel-for-5g-network-slicing/"},"type":"link"}],"text":"SDxCentral, 2026","type":"text"},{"text":").","type":"text"}],"type":"paragraph"},{"content":[{"text":"Unlike traditional AI recommendations, the system autonomously adjusts RAN policies in near real time based on KPI and contextual data.","type":"text"}],"type":"paragraph"},{"attrs":{"level":3},"content":[{"text":"Why It Matters","type":"text"}],"type":"heading"},{"content":[{"text":"This is a success-pattern case: gradual autonomy expansion with explicit controls. AWS also stated the solution remained in pilot stage, not production-ready.","type":"text"}],"type":"paragraph"},{"attrs":{"level":3},"content":[{"text":"Four-Element Application","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"content":[{"text":"Element","type":"text"}],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"Nokia x AWS Approach","type":"text"}],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"What Others Should Learn","type":"text"}],"type":"paragraph"}],"type":"tableHeader"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"<strong>1) Permission</strong>","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"AI scope limited to RAN policy adjustments","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Physically and logically separate mutable domains","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"<strong>2) Approval</strong>","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Human final approval in pilot stage","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Scale autonomy progressively, not all at once","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"<strong>3) Audit Trail</strong>","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Record KPI/context/rationale/policy-change chain","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Trace both input context and output decisions","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"<strong>4) Kill Switch</strong>","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Sandbox validation first; manual override retained","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Test extensively in isolated environment before production","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"}],"type":"table"},{"attrs":{"level":2},"content":[{"text":"Case Study Summary","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"content":[{"text":"Case","type":"text"}],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"Example","type":"text"}],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"Most Critical Gap","type":"text"}],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"Core Lesson","type":"text"}],"type":"paragraph"}],"type":"tableHeader"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"<strong>1</strong>","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Claude DXT privilege escalation","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Permission chain control","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Low-risk actions can become high-risk when chained","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"<strong>2</strong>","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Claude Code vulnerabilities","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Approval before communication","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Config files must be treated as execution paths","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"<strong>3</strong>","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Nokia x AWS autonomous 5G","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Success pattern","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Gradual autonomy + stage-by-stage guardrail validation builds trust","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"}],"type":"table"},{"content":[{"content":[{"text":"📎 ","type":"text"},{"marks":[{"type":"bold"}],"text":"Related Reading:","type":"text"}],"type":"paragraph"},{"content":[{"text":"- ","type":"text"},{"marks":[{"attrs":{"href":"/features/documentation/white-paper/21/welcome-to-the-age-of-agentsecops"},"type":"link"}],"text":"Welcome to the Age of AgentSecOps","type":"text"}],"type":"paragraph"},{"content":[{"text":"- ","type":"text"},{"marks":[{"attrs":{"href":"/features/documentation/white-paper/22/your-architect-vs-ai-agents"},"type":"link"}],"text":"Your Architect vs AI Agents","type":"text"}],"type":"paragraph"}],"type":"blockquote"},{"type":"horizontalRule"},{"attrs":{"level":1},"content":[{"text":"Chapter 5. Guardrail Checklist (Reusable)","type":"text"}],"type":"heading"},{"content":[{"text":"Use this checklist to assess your current state and identify immediate actions.","type":"text"}],"type":"paragraph"},{"content":[{"text":"Rate each item as:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"✅ Implemented","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"🔶 Partial","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"❌ Not started","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":2},"content":[{"text":"1) Permission","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"text":"Unique ID/account per AI agent","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Defined data scope per agent","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Defined system scope per agent","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Defined action scope (read/write/delete/send)","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Expiration for all permissions","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Ceiling limits (volume/value/range)","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Rules for cross-risk operation chaining","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"No shared API keys for agents","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":2},"content":[{"text":"2) Approval","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"text":"RACI defined for all AI-involved processes","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"No blank Accountable (A) ownership","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Risk-based approval granularity defined","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Decision-application approval flow documented","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"No external dispatch of AI output without human review","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Permission-setting changes require executive/CISO approval","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":2},"content":[{"text":"3) Audit Trail","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"text":"5W1H captured for all agent operations","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Action logs and rationale logs are separated","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Anti-tamper mechanism (e.g., hash chain)","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Retention/format/access policies defined","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"PII hashing/anonymization applied","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Capability to explain AI rationale within 24 hours after incident","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Periodic analysis for policy/process improvement","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":2},"content":[{"text":"4) Kill Switch","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"text":"Shutdown playbook exists","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Three-level escalation (Pause / Disable / Shutdown)","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Trigger thresholds and anomaly criteria defined","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Responsible responders and contacts specified","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Recovery conditions and approvers defined","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Log preservation included in shutdown playbook","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Manual override always available","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Drills performed regularly (at least quarterly)","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":2},"content":[{"text":"5) Organization & Governance","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"text":"CAIO (or equivalent) assigned","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Translation layer between tech and executive teams operates","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Approved AI-tool whitelist exists and is updated","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Shadow-AI assessment performed","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Enterprise AI-agent policy documented and socialized","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"AI incident response integrated into existing response framework","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":2},"content":[{"text":"Scoring Guide","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"✅ 25+ items","type":"text"},{"text":": Level 2 (systematized) -> move to Phase 3 continuous improvement","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"✅ 15–24 items","type":"text"},{"text":": Level 1 (partial) -> focus Phase 1–2 gap closure","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"✅ 14 or fewer","type":"text"},{"text":": Level 0 (initial) -> start with Phase 0 inventory/policy","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"type":"horizontalRule"},{"attrs":{"level":1},"content":[{"text":"Chapter 6. 90-Day Roadmap — PoC -> Limited Rollout -> Expansion","type":"text"}],"type":"heading"},{"attrs":{"level":2},"content":[{"text":"Four Phases","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"content":[{"text":"Phase","type":"text"}],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"Timeline","type":"text"}],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"Goal","type":"text"}],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"Exit Criteria","type":"text"}],"type":"paragraph"}],"type":"tableHeader"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"<strong>Phase 0: Inventory & Policy</strong>","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Day 1–14","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Visualize current state and align policy direction","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Checklist completed + policy approved","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"<strong>Phase 1: PoC</strong>","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Day 15–45","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Validate all four elements in one low-risk unit","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Four elements proven to work as designed","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"<strong>Phase 2: Limited Rollout</strong>","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Day 46–75","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Expand to 2–3 units with production data","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"No major incidents or all incidents handled correctly","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"<strong>Phase 3: Expansion Readiness</strong>","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Day 76–90","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Institutionalize policy, training, and audit systems","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Enterprise policy + training + audit plan completed","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"}],"type":"table"},{"attrs":{"level":2},"content":[{"text":"Phase 0 (Day 1–14)","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"text":"Inventory all active AI agents/tools","type":"text"}],"type":"paragraph"}],"type