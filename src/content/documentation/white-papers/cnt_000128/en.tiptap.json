{"content":[{"attrs":{"alt":"Guardrail Design in the AI Agent Era (Part 1: Philosophy & Design)","caption":"","src":"/documentation/white-papers/wp-thumb-28.webp"},"type":"image"},{"attrs":{"level":1},"content":[{"text":"Guardrail Design in the AI Agent Era: A Practical Framework for Permissions, Approvals, Audit Trails, and Shutdown Procedures","type":"text"}],"type":"heading"},{"content":[{"text":"📖 Estimated reading time: ~15 minutes","type":"text"}],"type":"paragraph"},{"type":"horizontalRule"},{"attrs":{"level":2},"content":[{"text":"Key Takeaway (1-Minute Read)","type":"text"}],"type":"heading"},{"content":[{"text":"As AI shifts from “AI that talks” to “AI that acts,” the top enterprise priority is ","type":"text"},{"marks":[{"type":"bold"}],"text":"guardrail design","type":"text"},{"text":".","type":"text"}],"type":"paragraph"},{"content":[{"text":"Guardrail design is a structured control framework built on ","type":"text"},{"marks":[{"type":"bold"}],"text":"four elements","type":"text"},{"text":":","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"content":[{"text":"Element","type":"text"}],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"In One Line","type":"text"}],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"Management Meaning","type":"text"}],"type":"paragraph"}],"type":"tableHeader"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"1) Permission","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Who can allow AI to do what, and to what extent","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Limit blast radius through least privilege","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"2) Approval","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Where human intervention must remain in decisions","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Eliminate accountability gaps with RACI","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"3) Audit Trail","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Trace of what AI did and why it did it","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Lifeline for accountability and incident response","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"4) Kill Switch","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Safe procedures to stop AI during anomalies","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Protect business continuity through fail-safe design","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"}],"type":"table"},{"content":[{"text":"As of February 2026, ","type":"text"},{"marks":[{"type":"bold"}],"text":"81% of AI agents are already beyond planning and in operation","type":"text"},{"text":", yet only ","type":"text"},{"marks":[{"type":"bold"}],"text":"14.4% have full security approval","type":"text"},{"text":" (source: ","type":"text"},{"marks":[{"attrs":{"href":"https://www.gravitee.io/blog/state-of-ai-agent-security-2026-report-when-adoption-outpaces-control"},"type":"link"}],"text":"Gravitee, State of AI Agent Security 2026","type":"text"},{"text":"). With 88% of organizations reporting AI-agent security incidents, most companies have effectively started running without guardrails.","type":"text"}],"type":"paragraph"},{"content":[{"text":"This white paper explains the framework from both perspectives:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Why it is necessary (CxO perspective)","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"How to implement it (operational perspective)","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"What you will gain from Part 1:","type":"text"}],"type":"paragraph"},{"content":[{"text":"- Structural understanding of AI-agent risk","type":"text"}],"type":"paragraph"},{"content":[{"text":"- Design principles and interaction of the four guardrail elements","type":"text"}],"type":"paragraph"},{"content":[{"text":"- Three common organizational failure patterns and how to avoid them","type":"text"}],"type":"paragraph"},{"content":[],"type":"paragraph"},{"content":[{"marks":[{"type":"bold"}],"text":"What you will gain from [Part 2](/features/documentation/white-paper/29/ai-agent-guardrails-governance-2026-implementation):","type":"text"}],"type":"paragraph"},{"content":[{"text":"- Three case studies (PC-operation agents / development AI vulnerabilities / autonomous critical infrastructure operations)","type":"text"}],"type":"paragraph"},{"content":[{"text":"- A practical checklist you can use immediately","type":"text"}],"type":"paragraph"},{"content":[{"text":"- A 90-day implementation roadmap (PoC -> limited rollout -> expansion)","type":"text"}],"type":"paragraph"}],"type":"blockquote"},{"type":"horizontalRule"},{"attrs":{"level":1},"content":[{"text":"Chapter 1. Why “AI That Executes” Is Risky Now","type":"text"}],"type":"heading"},{"attrs":{"level":2},"content":[{"text":"Structural Understanding of AI-Agent Risk","type":"text"}],"type":"heading"},{"attrs":{"level":3},"content":[{"text":"The Type of Risk Has Changed","type":"text"}],"type":"heading"},{"content":[{"text":"AI adoption is no longer experimental. A Nikkei BP survey (July 2025) reports that generative AI tool adoption in Japanese enterprises reached 64.4%, and AI agent adoption reached 29.7% (source: ","type":"text"},{"marks":[{"attrs":{"href":"https://xtech.nikkei.com/atcl/nxt/column/18/03314/090800004/"},"type":"link"}],"text":"Nikkei XTECH, 2025","type":"text"},{"text":").","type":"text"}],"type":"paragraph"},{"content":[{"text":"However, management must not miss one point: ","type":"text"},{"marks":[{"type":"bold"}],"text":"the risk profile of traditional generative AI and execution-capable AI agents is fundamentally different.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"content":[],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"Traditional GenAI (Conversational)","type":"text"}],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"AI Agents (Execution-Oriented)","type":"text"}],"type":"paragraph"}],"type":"tableHeader"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Role","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Suggests ideas and drafts","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Executes tasks on behalf of humans","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Operator","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Human clicks final action","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"AI directly operates systems","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Risk Type","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Misinformation, copyright issues","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Privilege escalation, data leaks, cascading mis-operations","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Impact Speed","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"There is human review time","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Decisions and execution complete in milliseconds","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Accountability","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Usually attributable to individual users","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Distributed across requester/approver/AI/vendor","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Control Difficulty","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Output filtering is often enough","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Requires layered controls across input/process/output/permissions","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"}],"type":"table"},{"content":[{"text":"A Deloitte AI Institute survey of 3,235 global leaders (Fall 2025) found that only about 1 in 5 companies has mature governance for AI agents (source: ","type":"text"},{"marks":[{"attrs":{"href":"https://www.deloitte.com/us/en/what-we-do/capabilities/applied-artificial-intelligence/content/state-of-ai-in-the-enterprise.html"},"type":"link"}],"text":"Deloitte, State of AI in the Enterprise 2026","type":"text"},{"text":"). Technology is advancing faster than control.","type":"text"}],"type":"paragraph"},{"attrs":{"level":3},"content":[{"text":"Accept the Reality: “Not Fully Controllable”","type":"text"}],"type":"heading"},{"content":[{"text":"In February 2026, Anthropic CEO Dario Amodei publicly rejected unrestricted model access requested by the U.S. Department of Defense (source: ","type":"text"},{"marks":[{"attrs":{"href":"https://techcrunch.com/2026/02/26/anthropic-ceo-stands-firm-as-pentagon-deadline-looms/"},"type":"link"}],"text":"TechCrunch, 2026","type":"text"},{"text":"). This exposed a core control issue.","type":"text"}],"type":"paragraph"},{"content":[{"text":"When enterprises integrate external AI models, internal algorithms and training data remain black boxes. Even vendors may not be able to guarantee full transparency to third parties.","type":"text"}],"type":"paragraph"},{"content":[{"text":"The right question is not “Can we fully control AI?” but ","type":"text"},{"marks":[{"type":"bold"}],"text":"“How do we design around what we cannot control?”","type":"text"}],"type":"paragraph"},{"content":[{"text":"NIST AI Risk Management Framework defines four functions:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Govern","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Map","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Measure","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Manage","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"Its implication is clear: ","type":"text"},{"marks":[{"type":"bold"}],"text":"design governance on the assumption that AI can behave unpredictably.","type":"text"}],"type":"paragraph"},{"attrs":{"level":3},"content":[{"text":"The Three Walls of the “Trust Gap”","type":"text"}],"type":"heading"},{"content":[{"text":"The root problem is a ","type":"text"},{"marks":[{"type":"bold"}],"text":"trust gap","type":"text"},{"text":".","type":"text"}],"type":"paragraph"},{"content":[{"text":"Trustworthiness in AI can be decomposed into three elements:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Explainability","type":"text"},{"text":": Can we trace how AI reached a decision?","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Accountability","type":"text"},{"text":": Can we consistently track human decision pathways around AI?","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Reliability","type":"text"},{"text":": Can we ensure AI-supported decisions do not produce unacceptable harm?","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"orderedList"},{"content":[{"text":"These gaps are not isolated; they form a chain that blocks adoption.","type":"text"}],"type":"paragraph"},{"attrs":{"alt":"Guardrail diagram 1","caption":"","src":"/documentation/white-papers/guardrail-framework-diagram-01.webp"},"type":"image"},{"content":[{"text":"Gartner’s AI in Organizations 2025 Survey shows roughly 53% of enterprises cite unclear reliability/accountability ownership as a top obstacle. The bottleneck is not model capability, but ","type":"text"},{"marks":[{"type":"bold"}],"text":"absence of ownership design","type":"text"},{"text":".","type":"text"}],"type":"paragraph"},{"attrs":{"level":3},"content":[{"text":"Shadow AI: The Invisible Threat","type":"text"}],"type":"heading"},{"content":[{"text":"When trust gaps persist, ","type":"text"},{"marks":[{"type":"bold"}],"text":"Shadow AI","type":"text"},{"text":" emerges.","type":"text"}],"type":"paragraph"},{"content":[{"text":"If management and IT cannot provide timely policy and approved options, teams adopt tools on their own. Gravitee reports only 47.1% of agents are actively monitored/protected on average; more than half run without meaningful security oversight.","type":"text"}],"type":"paragraph"},{"content":[{"text":"More critically, only 14.4% of production agents had full security approval. The rest operate outside governance boundaries.","type":"text"}],"type":"paragraph"},{"content":[{"text":"Gartner predicts that by end of 2027, over 40% of agentic AI projects will be canceled due to rising costs, unclear value, and weak risk control (cited via: ","type":"text"},{"marks":[{"attrs":{"href":"https://www.forbes.com/sites/markminevich/2025/12/31/agentic-ai-takes-over-11-shocking-2026-predictions/"},"type":"link"}],"text":"Forbes, 2025","type":"text"},{"text":").","type":"text"}],"type":"paragraph"},{"attrs":{"level":3},"content":[{"text":"Structural Challenges Specific to Japanese Enterprises","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Ringi culture vs AI speed","type":"text"},{"text":": multi-stage consensus is slower than millisecond AI execution.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Bottom-up operations as double-edged sword","type":"text"},{"text":": departmental autonomy can spread unmanaged AI risk.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Policy progress vs operational reality gap","type":"text"},{"text":": regulations and guidelines advance, but field-level prompt/supplier risk remains hard to cover.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":2},"content":[{"text":"Chapter 1 Summary","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Recognize qualitative risk shift","type":"text"},{"text":": from information errors to privilege and cascading-operation risk.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Abandon the full-control illusion","type":"text"},{"text":": black-box external models are unavoidable.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Close trust gaps through design—not documents","type":"text"},{"text":": explainability, accountability, and reliability must be designed in.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"orderedList"},{"type":"horizontalRule"},{"attrs":{"level":1},"content":[{"text":"Chapter 2. The Four-Element Guardrail Framework","type":"text"}],"type":"heading"},{"content":[{"text":"This chapter breaks guardrail design into four components and explains their meaning, interdependencies, and design guidance.","type":"text"}],"type":"paragraph"},{"attrs":{"level":2},"content":[{"text":"Overview: How the Four Elements Work Together","type":"text"}],"type":"heading"},{"content":[{"text":"Guardrails are not one-off controls; they are a ","type":"text"},{"marks":[{"type":"bold"}],"text":"cyclical control system","type":"text"},{"text":".","type":"text"}],"type":"paragraph"},{"attrs":{"alt":"Guardrail diagram 2","caption":"","src":"/documentation/white-papers/guardrail-framework-diagram-02.webp"},"type":"image"},{"content":[{"text":"The four form a control hierarchy: ","type":"text"},{"marks":[{"type":"bold"}],"text":"prevention -> human intervention -> recording -> emergency response","type":"text"},{"text":", and feed back from shutdown results to permission redesign.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"content":[{"text":"Missing Element","type":"text"}],"type":"paragraph"}],"type":"tableHeader"},{"content":[{"content":[{"text":"Resulting Risk","type":"text"}],"type":"paragraph"}],"type":"tableHeader"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"Permission undefined","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"AI reaches data/systems it should never touch","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"Approval not designed","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Cannot trace who authorized action","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"No audit trail","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Root-cause analysis and prevention become impossible","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"},{"content":[{"content":[{"content":[{"text":"No shutdown procedure","type":"text"}],"type":"paragraph"}],"type":"tableCell"},{"content":[{"content":[{"text":"Damage continues even after anomaly detection","type":"text"}],"type":"paragraph"}],"type":"tableCell"}],"type":"tableRow"}],"type":"table"},{"attrs":{"level":2},"content":[{"text":"Element 1: Permission","type":"text"}],"type":"heading"},{"attrs":{"level":3},"content":[{"text":"CxO View","type":"text"}],"type":"heading"},{"content":[{"text":"Control starts with clear boundaries of what is allowed vs prohibited. AI agents require stricter control than humans because they run continuously, operate across systems, execute at high speed, and do not self-stop when interpreting instructions incorrectly.","type":"text"}],"type":"paragraph"},{"content":[{"text":"Gravitee reports 45.6% of agents still authenticate with shared API keys, while only 21.9% are managed as independent identities (source: ","type":"text"},{"marks":[{"attrs":{"href":"https://www.gravitee.io/blog/state-of-ai-agent-security-2026-report-when-adoption-outpaces-control"},"type":"link"}],"text":"Gravitee, 2026","type":"text"},{"text":").","type":"text"}],"type":"paragraph"},{"attrs":{"level":3},"content":[{"text":"Operational View: Three Axes","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Scope","type":"text"},{"text":": data scope, system scope, action scope","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Duration","type":"text"},{"text":": task-bound, time-bound, event-bound","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Ceiling","type":"text"},{"text":": value, volume, and blast-radius limits","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"orderedList"},{"content":[{"text":"This enables concrete definitions like: “Sales agent can read only sales customer data, valid until month-end, max 50 operations/day.”","type":"text"}],"type":"paragraph"},{"attrs":{"level":2},"content":[{"text":"Element 2: Approval","type":"text"}],"type":"heading"},{"attrs":{"level":3},"content":[{"text":"CxO View","type":"text"}],"type":"heading"},{"content":[{"text":"The most common ambiguity is responsibility: who approved what. The solution is not post-incident blame assignment, but pre-defined responsibility architecture.","type":"text"}],"type":"paragraph"},{"attrs":{"level":3},"content":[{"text":"Operational View: Extend RACI for AI Agents","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"text":"AI can hold ","type":"text"},{"marks":[{"type":"bold"}],"text":"R (Responsible)","type":"text"},{"text":" but never ","type":"text"},{"marks":[{"type":"bold"}],"text":"A (Accountable)","type":"text"},{"text":".","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Zero blank A cells","type":"text"},{"text":" across all processes.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Approval granularity must match risk levels.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"alt":"Guardrail diagram 3","caption":"","src":"/documentation/white-papers/guardrail-framework-diagram-03.webp"},"type":"image"},{"attrs":{"level":2},"content":[{"text":"Element 3: Audit Trail","type":"text"}],"type":"heading"},{"attrs":{"level":3},"content":[{"text":"CxO View","type":"text"}],"type":"heading"},{"content":[{"text":"Audit trail is not just insurance. It is a management asset for:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"Incident response","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Compliance evidence","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Continuous operations improvement","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"orderedList"},{"attrs":{"level":3},"content":[{"text":"Operational View","type":"text"}],"type":"heading"},{"content":[{"text":"Separate two logs:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Action Log","type":"text"},{"text":": what happened (5W1H + anti-tamper hash chain)","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Explainable Action Log","type":"text"},{"text":": why AI chose this action (policies, alternatives, rationale)","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"Without the second, post-incident accountability is incomplete.","type":"text"}],"type":"paragraph"},{"attrs":{"level":2},"content":[{"text":"Element 4: Kill Switch","type":"text"}],"type":"heading"},{"attrs":{"level":3},"content":[{"text":"CxO View","type":"text"}],"type":"heading"},{"content":[{"text":"Automation without fail-safe is equivalent to runaway risk.","type":"text"}],"type":"paragraph"},{"attrs":{"level":3},"content":[{"text":"Operational View: Three-Level Escalation","type":"text"}],"type":"heading"},{"attrs":{"alt":"Guardrail diagram 4","caption":"","src":"/documentation/white-papers/guardrail-framework-diagram-04.webp"},"type":"image"},{"content":[{"text":"Design principles:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"Define recovery conditions when defining stop conditions","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Always keep manual override","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Preserve logs first during shutdown","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":2},"content":[{"text":"Integrated Self-Assessment","type":"text"}],"type":"heading"},{"content":[{"text":"Use the following maturity model:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Level 0","type":"text"},{"text":": not started","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Level 1","type":"text"},{"text":": partially implemented","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Level 2","type":"text"},{"text":": systematized","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"Most enterprises are currently between Level 0 and 1. What matters is a clear path to Level 2.","type":"text"}],"type":"paragraph"},{"attrs":{"level":2},"content":[{"text":"Chapter 2 Summary","type":"text"}],"type":"heading"},{"content":[{"text":"When these four elements are in place, AI shifts from “uncontrollable threat” to ","type":"text"},{"marks":[{"type":"bold"}],"text":"“stoppable, traceable, correctable system.”","type":"text"}],"type":"paragraph"},{"type":"horizontalRule"},{"attrs":{"level":1},"content":[{"text":"Chapter 3. Three Organizational Failure Patterns","type":"text"}],"type":"heading"},{"attrs":{"level":2},"content":[{"text":"1) Trust Gap","type":"text"}],"type":"heading"},{"content":[{"text":"The technical team and management often define “trust” differently. Engineering emphasizes precision and response speed; management emphasizes explainability, auditability, and legal defensibility.","type":"text"}],"type":"paragraph"},{"content":[{"marks":[{"type":"bold"}],"text":"Mitigation","type":"text"},{"text":": build a translation layer","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"Risk dashboard mapping technical metrics to business impact","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Phased approval gates","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Regular bridge meetings across tech/legal/management","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":2},"content":[{"text":"2) Consensus Cost","type":"text"}],"type":"heading"},{"content":[{"text":"Trying to secure full-company agreement from day one causes paralysis.","type":"text"}],"type":"paragraph"},{"attrs":{"alt":"Guardrail diagram 5","caption":"","src":"/documentation/white-papers/guardrail-framework-diagram-05.webp"},"type":"image"},{"content":[{"marks":[{"type":"bold"}],"text":"Mitigation","type":"text"},{"text":": phase consensus scope","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"Phase 0: design policy","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Phase 1: single low-risk unit PoC","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Phase 2: 2–3 units with medium-risk operations","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Phase 3: enterprise policy rollout","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":2},"content":[{"text":"3) Shadow AI","type":"text"}],"type":"heading"},{"content":[{"text":"When official paths are slow or unusable, teams adopt unapproved tools.","type":"text"}],"type":"paragraph"},{"content":[{"marks":[{"type":"bold"}],"text":"Mitigation","type":"text"},{"text":": “safe alternatives before restrictions”","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"Visualize real usage","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Provide safe, usable official alternatives","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Support migration, then tighten unapproved access","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"orderedList"},{"attrs":{"level":3},"content":[{"text":"Breaking the Chain","type":"text"}],"type":"heading"},{"content":[{"text":"The three failures are linked.","type":"text"}],"type":"paragraph"},{"attrs":{"alt":"Guardrail diagram 6","caption":"","src":"/documentation/white-papers/guardrail-framework-diagram-06.webp"},"type":"image"},{"content":[{"text":"The highest-ROI intervention is a fast, controlled Phase 1 PoC with all four guardrail elements included.","type":"text"}],"type":"paragraph"},{"attrs":{"level":2},"content":[{"text":"Chapter 3 Summary","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"text":"Trust gap -> build translation layer","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Consensus cost -> phased expansion with evidence","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Shadow AI -> provide safe alternatives first","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"type":"horizontalRule"},{"attrs":{"level":1},"content":[{"text":"End of Part 1: Your Next Move","type":"text"}],"type":"heading"},{"content":[{"t