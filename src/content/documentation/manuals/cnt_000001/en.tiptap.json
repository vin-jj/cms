{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"🧭 Before You Start"}]},{"type":"paragraph","content":[{"type":"hardBreak"},{"type":"text","marks":[{"type":"bold"}],"text":"QueryPie ACP Community Edition"},{"type":"text","text":" lets you experience the core features available in "},{"type":"text","marks":[{"type":"bold"}],"text":"QueryPie Enterprise"},{"type":"text","text":"."}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Database Access Controller"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"System Access Controller"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Kubernetes Access Controller"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Web Access Controller"}]}]}]},{"type":"paragraph"},{"type":"paragraph","content":[{"type":"text","text":"However, the Community Edition supports "},{"type":"text","marks":[{"type":"bold"}],"text":"up to 5 user activations"},{"type":"text","text":". (If you need to register more than 5 users, please consider upgrading to the "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://querypie.com/plans","target":"_blank","rel":"noopener noreferrer nofollow","class":"link_link___HMQX link_markdown__DysGk","title":null}},{"type":"underline"}],"text":"Enterprise Plan"},{"type":"text","text":")."}]},{"type":"paragraph","content":[{"type":"text","text":"QueryPie runs as a typical web application and also includes a proxy-based network server feature."}]},{"type":"paragraph"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"🖥️ Recommended Server Specifications"}]},{"type":"paragraph"},{"type":"paragraph","content":[{"type":"text","text":"To ensure smooth installation and operation of QueryPie Community Edition, we recommend the following system environment:"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Type"}]}]},{"type":"tableHeader","attrs":{"colspan":1,"rowspan":1,"colwidth":null},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"Specifications"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Basic specifications"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null},"content":[{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Hardware : AMD64 Architecture, CPU 4 vCPUs, Memory 16 GiB, Disk 100 GiB+"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"AWS EC2 : m6i.xlarge, m7i.xlarge"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"GCP Compute Engine : c4-standard-4, n4-standard-4 (or AMD64 architecture -standard-4 models)"}]}]}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"For Trial use"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null},"content":[{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Hardware: ARM64 Architecture, 4 vCPUs, Memory 16 GiB, Disk 30 GiB+"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"AWS EC2 : t4g.xlarge, m7g.xlarge"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"OS: Linux or macOS with Docker"}]}]}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Recommended specifications for multi-user production environment"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null},"content":[{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Hardware: AMD64 Architecture, 8 vCPUs, Memory 32 GiB, Disk 100 GiB+"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"AWS EC2 : m6i.2xlarge, m7i.2xlarge"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"GCP Compute Engine : c4-standard-8, n4-standard-8 (or AMD64 architecture -standard-8 models)"}]}]}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"OS"}]}]},{"type":"tableCell","attrs":{"colspan":1,"rowspan":1,"colwidth":null},"content":[{"type":"paragraph","content":[{"type":"text","text":"Linux with Docker or Podman"}]}]}]}]},{"type":"paragraph"},{"type":"paragraph","content":[{"type":"text","text":"ARM64 Architecture CPU or macOS environments are recommended for trial use and testing purposes for developers."},{"type":"hardBreak"},{"type":"text","text":"For detailed requirements, please refer to the document below:"}]},{"type":"paragraph","content":[{"type":"text","text":"📄 "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://querypie.atlassian.net/wiki/spaces/QCP/pages/865009675/Prerequisites+for+Installation+-+Single+Machine+EN?atl_f=PAGETREE","target":"_blank","rel":"noopener noreferrer nofollow","class":"link_link___HMQX link_markdown__DysGk","title":null}},{"type":"underline"}],"text":"Prerequisites for Installation - Single Machine (EN)"}]},{"type":"paragraph"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"🐳 Installation Method"}]},{"type":"paragraph","content":[{"type":"text","text":"Installation is based on a Docker image and can be completed automatically with a single command."}]},{"type":"paragraph"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"1. Run the Command in the Terminal"}]},{"type":"paragraph","content":[{"type":"text","text":"After accessing your Linux server’s terminal, run the following command from your home directory:"}]},{"type":"codeBlock","attrs":{"language":"code"},"content":[{"type":"text","text":"bash <(curl https://dl.querypie.com/setup.v2.sh)"}]},{"type":"paragraph"},{"type":"paragraph","content":[{"type":"text","text":"⏱️ Installation typically takes "},{"type":"text","marks":[{"type":"bold"}],"text":"7~10 minutes"},{"type":"text","text":"."}]},{"type":"image","attrs":{"src":"/documentation/manuals/install-guide-1.webp","alt":"Installation has started.","title":null,"width":null,"height":null}},{"type":"paragraph"},{"type":"image","attrs":{"src":"/documentation/manuals/install-guide-2.webp","alt":"Installation is complete.","title":null,"width":null,"height":null}},{"type":"paragraph"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"2. Obtain a License During Installation"}]},{"type":"paragraph","content":[{"type":"text","text":"QueryPie Community Edition requires license registration. While installation is in progress, submit the "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://www.querypie.com/querypie/license/community/apply","target":"_blank","rel":"noopener noreferrer nofollow","class":"link_link___HMQX link_markdown__DysGk","title":null}},{"type":"underline"}],"text":"license application form"},{"type":"text","text":". A .crt text file will be sent to the email address you provided."}]},{"type":"paragraph"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"3. Access After Installation"}]},{"type":"paragraph","content":[{"type":"text","text":"Once installation is complete, access QueryPie in your browser at:"}]},{"type":"codeBlock","attrs":{"language":null},"content":[{"type":"text","text":"http://<server IP address>\nor\nhttps://<server IP address>"}]},{"type":"paragraph","content":[{"type":"text","text":"The IP address of the Linux server where QueryPie is installed must be accessible from the user’s PC."}]},{"type":"paragraph"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"4. Register the License"}]},{"type":"paragraph","content":[{"type":"text","text":"Upload the .crt file received by email, or copy and paste the PEM-formatted text content."}]},{"type":"paragraph"},{"type":"image","attrs":{"src":"/documentation/manuals/install-guide-3.webp","alt":"Enter the license in PEM format.","title":null,"width":null,"height":null}},{"type":"paragraph"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"5. Log In"}]},{"type":"paragraph","content":[{"type":"text","text":"Log in with the default account below."},{"type":"hardBreak"},{"type":"text","text":"On your first login, you will be prompted to change your password for security. Please set a new password to begin using the service."},{"type":"hardBreak"},{"type":"text","text":"- ID: "},{"type":"text","marks":[{"type":"code"}],"text":"qp-admin"},{"type":"hardBreak"},{"type":"text","text":"- Password: "},{"type":"text","marks":[{"type":"code"}],"text":"querypie"}]},{"type":"paragraph"},{"type":"image","attrs":{"src":"/documentation/manuals/install-guide-4.webp","alt":"This is the initial login screen.","title":null,"width":null,"height":null}},{"type":"paragraph"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"6. Installation Complete 🎉"}]},{"type":"paragraph","content":[{"type":"text","text":"Congratulations! Installation is complete. Refer to the "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://docs.querypie.com/en/administrator-manual","target":"_blank","rel":"noopener noreferrer nofollow","class":"link_link___HMQX link_markdown__DysGk","title":null}},{"type":"underline"}],"text":"Administrator Manual"},{"type":"text","text":" to proceed with environment setup."}]},{"type":"paragraph"},{"type":"image","attrs":{"src":"/documentation/manuals/install-guide-5.webp","alt":"Welcome to the initial login screen.","title":null,"width":null,"height":null}},{"type":"paragraph"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"🔑 About the License"}]},{"type":"paragraph","content":[{"type":"text","text":"- To use QueryPie ACP, you must register a valid license after installation."},{"type":"hardBreak"},{"type":"text","text":"- The license is provided as a text file with a .crt extension."},{"type":"hardBreak"},{"type":"text","text":"- The license will be sent to the email address you entered when applying."},{"type":"hardBreak"},{"type":"text","text":"- Each license is valid for one year from the date of issue."},{"type":"hardBreak"},{"type":"text","text":"- The license is issued to the applicant personally and cannot be transferred to a third party."}]},{"type":"paragraph"},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"💬 Support & Inquiries"}]},{"type":"paragraph","content":[{"type":"text","text":"Join our community on the "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://discord.gg/Cu39M55gMk","target":"_blank","rel":"noopener noreferrer nofollow","class":"link_link___HMQX link_markdown__DysGk","title":null}},{"type":"underline"}],"text":"Official QueryPie Discord Channel"},{"type":"text","text":" to ask questions and share insights with other users."}]},{"type":"paragraph"},{"type":"paragraph"}]}