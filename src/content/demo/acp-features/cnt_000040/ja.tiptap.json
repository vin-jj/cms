{"content":[{"attrs":{"src":"https://www.youtube.com/embed/E_NEaALFgf4?si=tfN3Qo-Q5ZKx6MGJ"},"type":"youtube"},{"attrs":{"level":1},"content":[{"text":"Overview","type":"text"}],"type":"heading"},{"content":[{"text":"You can manage access policies for Kubernetes clusters within your organization. Kubernetes policies operate as ","type":"text"},{"marks":[{"type":"bold"}],"text":"Policy as Code (PaC)","type":"text"},{"text":", functioning in YAML format. These policies allow you to define access rules for cluster resources, API scopes, resource tags, and user attributes, as well as configure accessible IP addresses. Once policies are defined, they can be compiled into Roles, which aggregate multiple policies into a single role definition.","type":"text"}],"type":"paragraph"},{"content":[{"text":"QueryPie supports ","type":"text"},{"marks":[{"type":"bold"}],"text":"Role-Based Access Control (RBAC)","type":"text"},{"text":", enabling organizations to allow or restrict user access to Kubernetes based on predefined roles.","type":"text"}],"type":"paragraph"},{"attrs":{"level":1},"content":[{"text":"Setting Kubernetes Access Policies","type":"text"}],"type":"heading"},{"content":[{"text":"STEP 1 Navigate to the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Policies","type":"text"},{"text":" menu and click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Create Policy","type":"text"},{"text":" button and enter the following details:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Name:","type":"text"},{"text":" A unique name to identify the policy.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Description:","type":"text"},{"text":" Provide detailed information about the policy.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 2 Select the created policy and click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Go to Editor Mode","type":"text"},{"text":" button. Modify the policy content in one of the following ways:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"Use the buttons on the right panel to insert or modify code.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Directly edit the code in the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Code Editor","type":"text"},{"text":".","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Use the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Errors","type":"text"},{"text":" tab at the bottom to debug errors in the edited code.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 3 Once the policy is defined, click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Save","type":"text"},{"text":" button in the top-right corner to save your change","type":"text"}],"type":"paragraph"},{"attrs":{"level":1},"content":[{"text":"Creating a Role","type":"text"}],"type":"heading"},{"content":[{"text":"STEP 1 Navigate to the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Roles","type":"text"},{"text":" menu and click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Create Role","type":"text"},{"text":" button and enter the following details:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Name:","type":"text"},{"text":" A unique name to identify the role.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Description:","type":"text"},{"text":" Provide detailed information about the role.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 2 Select the created role and click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Assign Policies","type":"text"},{"text":" button. Add one or more previously created policies to the role.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Users/Groups:","type":"text"},{"text":" Displays the list of users or groups assigned to the role.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Clusters:","type":"text"},{"text":" Displays the list of clusters accessible with the role.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":1},"content":[{"text":"Granting a Role","type":"text"}],"type":"heading"},{"content":[{"text":"STEP 1 Navigate to the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Access Control","type":"text"},{"text":" menu and choose the user or group to whom the role will be assigned.","type":"text"}],"type":"paragraph"},{"content":[{"text":"STEP 2 Click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Grant Roles","type":"text"},{"text":" button on the right, and heck the box for one or more roles to assign and set an expiration date for the role.","type":"text"}],"type":"paragraph"},{"content":[{"text":"STEP 3 Click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Grant","type":"text"},{"text":" button to finalize the assignment.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"Go to the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Clusters","type":"text"},{"text":" tab to view the resources accessible under the assigned role.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"}],"type":"doc"}