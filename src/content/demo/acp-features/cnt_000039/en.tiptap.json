{"content":[{"attrs":{"src":"https://www.youtube.com/embed/ouChaeaVu98?si=X5XIJb94QV6Q-bdy"},"type":"youtube"},{"attrs":{"level":1},"content":[{"text":"Overview","type":"text"}],"type":"heading"},{"content":[{"text":"Access policies for servers operate based on YAML code, similar to Infrastructure as Code (IaC). You can configure the allowed days and times for access, set the allowable IP addresses, enable auditing, specify whether agents can be used, and define the maximum number of sessions per user. Role-Based Access Control (RBAC) is used to allow or restrict user access to servers based on roles within your organization. A role combines multiple policies into a single, unified entity, and administrators can assign or revoke roles for users or user groups.","type":"text"}],"type":"paragraph"},{"attrs":{"level":1},"content":[{"text":"Configure Server Policies","type":"text"}],"type":"heading"},{"content":[{"text":"STEP 1 Go to the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Policies","type":"text"},{"text":" menu and click ","type":"text"},{"marks":[{"type":"code"}],"text":"Create Policy","type":"text"},{"text":". Enter the following details:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Name:","type":"text"},{"text":" Enter a name to identify the policy.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Description:","type":"text"},{"text":" Enter additional information about the policy.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 2 Select the created policy and click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Go to Editor Mode","type":"text"},{"text":" button to modify the policy content using the following method.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"Use the buttons on the right to insert or modify content in the code.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Add Resource:","type":"text"},{"text":" Select server groups and accounts.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Add Actions:","type":"text"},{"text":" Select the protocols and command templates to allow.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Directly modify the code in the Code Editor screen.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Use the Errors tab at the bottom to debug any errors in the code you’ve edited.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 3 Once the access policy is defined, click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Save","type":"text"},{"text":" button in the upper right corner to save the policy.","type":"text"}],"type":"paragraph"},{"attrs":{"level":1},"content":[{"text":"Creating a Role","type":"text"}],"type":"heading"},{"content":[{"text":"STEP 1 Go to the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Roles","type":"text"},{"text":" menu and click ","type":"text"},{"marks":[{"type":"code"}],"text":"Create Role","type":"text"},{"text":". Enter the following details:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Name:","type":"text"},{"text":" Enter a name to identify the role.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Description:","type":"text"},{"text":" Enter additional information about the role.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 2 Select the created Role, click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Assign Policies","type":"text"},{"text":" button, and add one or more Policies.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Users/Groups:","type":"text"},{"text":" This tab lists the users or groups assigned to the role.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Servers:","type":"text"},{"text":" This tab lists the servers accessible through the role.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":1},"content":[{"text":"Grant Server Roles","type":"text"}],"type":"heading"},{"content":[{"text":"STEP 1 Go to the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Access Control","type":"text"},{"text":" menu and select the user or group to whom you want to grant the privilege.","type":"text"}],"type":"paragraph"},{"content":[{"text":"STEP 2 Go to the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Roles","type":"text"},{"text":" tab and click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Grant Roles","type":"text"},{"text":" button on the right.","type":"text"}],"type":"paragraph"},{"content":[{"text":"STEP 3 Select the checkbox for one or more Roles to grant and specify the expiration date.","type":"text"}],"type":"paragraph"},{"content":[{"text":"STEP 4 Click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Grant","type":"text"},{"text":" button to finalize the Role assignment.","type":"text"}],"type":"paragraph"}],"type":"doc"}