{"content":[{"attrs":{"src":"https://www.youtube.com/embed/fzdHHwI4mik?si=0qJ9IsfaHLd2iZK1"},"type":"youtube"},{"attrs":{"level":1},"content":[{"text":"Overview","type":"text"}],"type":"heading"},{"content":[{"text":"The cloud synchronization feature enables you to synchronize servers from multiple cloud platforms at once or manually register them. This tutorial provides instructions for syncing AWS resources to register them in QueryPie and for manually registering on-premises servers. Also, You can group multiple servers to apply accessible accounts and policies at once. By creating server groups according to specific purposes, you can conveniently manage policies in bulk and grant the permissions for these grouped servers to individual users or user groups all at once.","type":"text"}],"type":"paragraph"},{"attrs":{"level":1},"content":[{"text":"Syncing and Managing Servers via AWS Integration","type":"text"}],"type":"heading"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Precondition:","type":"text"},{"text":" Specific policies are required for server synchronization - AmazonEC2ReadOnlyAccess","type":"text"}],"type":"paragraph"}],"type":"blockquote"},{"content":[{"text":"STEP 1 Navigate to the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Cloud Provider","type":"text"},{"text":" menu and click ","type":"text"},{"marks":[{"type":"code"}],"text":"Create Provider","type":"text"},{"text":". Enter the following details:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Name:","type":"text"},{"text":" A unique name to identify the provider.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Cloud Provider:","type":"text"},{"text":" : Select \"Amazon Web Services\".","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Region:","type":"text"},{"text":" Specify the region of the resources to synchronize.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Credential:","type":"text"},{"text":" Choose one of the following options:","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Default Credential:","type":"text"},{"text":" Assign a policy to the IAM role of the EC2 instance where QueryPie is installed to synchronize resources within the same AWS account.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Cross Account Role:","type":"text"},{"text":" Create an IAM role to synchronize resources from another AWS account.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Access Key:","type":"text"},{"text":" Enter the AWS account's access key to synchronize resources.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Search Filter:","type":"text"},{"text":" A list of specific types of resources you want to synchronize.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"The search filter operates similarly to AWS search methods, allowing you to use values such as names and tags for filtering.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"marks":[{"type":"code"}],"text":"Enter the Key value → Select the search condition → Enter the Value","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Replication Frequency:","type":"text"},{"text":" How synchronization should occur.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Manual:","type":"text"},{"text":" A method where synchronization is performed manually only when desired.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Scheduling:","type":"text"},{"text":" A method that synchronizes resources through periodic scheduling. Cron expressions are provided.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Port:","type":"text"},{"text":" Allow you to specify the default ports of the servers to be synchronized when importing servers. This applies only during the initial synchronization.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 2 Select the provider created in the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Cloud Provider","type":"text"},{"text":" menu.","type":"text"}],"type":"paragraph"},{"content":[{"text":"STEP 3 Click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Synchronize","type":"text"},{"text":" button to sync AWS resources.","type":"text"}],"type":"paragraph"},{"content":[{"text":"STEP 4 Check the synchronized resources in the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Servers","type":"text"},{"text":" menu.","type":"text"}],"type":"paragraph"},{"attrs":{"level":1},"content":[{"text":"Manually register individual servers and manage them as server groups.","type":"text"}],"type":"heading"},{"content":[{"text":"STEP 1 Go to the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Servers","type":"text"},{"text":" menu and click ","type":"text"},{"marks":[{"type":"code"}],"text":"Create Server","type":"text"},{"text":". Enter the following details:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Name:","type":"text"},{"text":" Enter a name to identify the server.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Host:","type":"text"},{"text":" Enter the server's host, which can be in the form of a domain or IP address.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Server OS:","type":"text"},{"text":" Select the server's operating system.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"OS Version:","type":"text"},{"text":" Enter detailed information about the server's OS.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Port:","type":"text"},{"text":" Enter the port for the connection.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"TELNET/FTP:","type":"text"},{"text":" This option is only displayed if TELNET is enabled under the ","type":"text"},{"marks":[{"type":"bold"}],"text":"\"Using insecure protocols\"","type":"text"},{"text":" section in the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Security","type":"text"},{"text":" menu.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 2 If needed, you can manually add ","type":"text"},{"marks":[{"type":"bold"}],"text":"tags","type":"text"},{"text":" to individual servers.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"These tags can be used for filtering when viewing the server list or adding servers to a server group.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Key:","type":"text"},{"text":" Enter a key to identify the tag (up to 512 characters). The key is mandatory and must be unique, with duplicates checked in a case-sensitive manner.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Value:","type":"text"},{"text":" Enter a value for filtering purposes (up to 256 characters).","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 3 Click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Save","type":"text"},{"text":" button to save, and check the created individual servers in the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Servers","type":"text"},{"text":" menu.","type":"text"}],"type":"paragraph"},{"content":[{"text":"STEP 4 Go to the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Server groups","type":"text"},{"text":" menu and click ","type":"text"},{"marks":[{"type":"code"}],"text":"Create Group","type":"text"},{"text":". Enter the following details:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Name:","type":"text"},{"text":" Enter a name to distinguish the server group on the screen.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Description:","type":"text"},{"text":" Enter additional information about the server group.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 5 Select servers to include in the server group using the following two methods:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"Specify the tags of servers in ","type":"text"},{"marks":[{"type":"bold"}],"text":"Server Tags","type":"text"},{"text":" to retrieve the servers matching those tags.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"orderedList"},{"content":[{"content":[{"content":[{"text":"This allows for dynamic management of server group targets.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Servers added through tags cannot be manually removed from the server table; you must modify the tags in ","type":"text"},{"marks":[{"type":"bold"}],"text":"Server Tags","type":"text"},{"text":".","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"content":[{"content":[{"text":"Click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Add Servers","type":"text"},{"text":" button to manually add servers.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"orderedList"},{"content":[{"text":"STEP 6 Enter the accounts required for server access.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Account:","type":"text"},{"text":" Enter a name to distinguish the individual account.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Auto Login:","type":"text"},{"text":" You can set auto-login. If set to Off, only password authentication can be used.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Provisioning:","type":"text"},{"text":" Allows you to designate server accounts for automated password changes.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"This option is available only when Password Provisioning is enabled under ","type":"text"},{"marks":[{"type":"bold"}],"text":"Administrator > General > Company Management > Security > Server Connection Security","type":"text"},{"text":".","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"It will only appear when Secret Store is set to QueryPie.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Auth Type:","type":"text"},{"text":" Select the authentication method for the individual account.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Authority","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"If the authentication method is Password, enter the password for authentication.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"If it is an SSH Key, select a key already registered in SSH Key Configurations.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Protocols:","type":"text"},{"text":" Set whether to allow SSH or SFTP access with the account.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 7 Register the Server Group Owner and click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Save","type":"text"},{"text":" button to save the server group.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"The ","type":"text"},{"marks":[{"type":"bold"}],"text":"Server Group Owner","type":"text"},{"text":" can be designated as an approver in Workflow.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"}],"type":"doc"}