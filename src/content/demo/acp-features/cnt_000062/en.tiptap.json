{"content":[{"attrs":{"src":"https://www.youtube.com/embed/4hFzMYRk8_Y?si=mQ-ds7ngt-XiAQ2S"},"type":"youtube"},{"attrs":{"level":1},"content":[{"text":"Overview","type":"text"}],"type":"heading"},{"content":[{"text":"SQL requests allow users to execute queries on specific DB connections for which they do not have permissions. Once approved, the requester can execute the approved query a single time and view the results.","type":"text"}],"type":"paragraph"},{"attrs":{"level":1},"content":[{"text":"Submitting an SQL Access Request","type":"text"}],"type":"heading"},{"content":[{"text":"STEP 1 Access the ","type":"text"},{"marks":[{"type":"bold"}],"text":"SQL Request","type":"text"},{"text":" page through the following paths:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"Attempt to execute a restricted query in the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Web Editor","type":"text"},{"text":" and click the ","type":"text"},{"marks":[{"type":"code"}],"text":"SEND SQL Requests","type":"text"},{"text":" button","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Workflow > Submit Request > SQL Request","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 2 Select approval rules and assign approvers.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Approval Rule:","type":"text"},{"text":" Choose an approval rule from the list created by the administrator in ","type":"text"},{"marks":[{"type":"bold"}],"text":"General > Approval Rules","type":"text"},{"text":".","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Approval rules determine who must approve the request. If the rule specifies approvers, they will be automatically assigned.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Approver:","type":"text"},{"text":" Use the ","type":"text"},{"marks":[{"type":"code"}],"text":"+","type":"text"},{"text":" button to add approvers at each stage of the approval workflow.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"A single assignee can complete the approval request:","type":"text"},{"text":" Any one approver in a group can approve the request.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"All assignees must approve this request:","type":"text"},{"text":" All assigned approvers must approve the request for it to proceed.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 3 After entering all details, click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Submit","type":"text"},{"text":" button to send the request for approval.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Title:","type":"text"},{"text":" Provide a title for the request.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Connection:","type":"text"},{"text":" Select the target DB connection for SQL execution. Only connections where you have access will be shown.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Database:","type":"text"},{"text":" Choose the specific database within the connection for the query execution.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Content Type:","type":"text"},{"text":" Select how to provide the SQL query:","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Text:","type":"text"},{"text":" Write the query (up to 9,999 lines, 10 million characters, or 5MB).","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"File:","type":"text"},{"text":" Upload a ","type":"text"},{"marks":[{"type":"code"}],"text":".sql","type":"text"},{"text":" file.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Target Date:","type":"text"},{"text":" Specify the desired execution date for the query (default: request submission date).","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Due Date:","type":"text"},{"text":" Specify when the approval/execution will expire (default: one year from the request date).","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Reason for Request:","type":"text"},{"text":" Provide a reason for requesting SQL execution.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":1},"content":[{"text":"Approving a Request","type":"text"}],"type":"heading"},{"content":[{"text":"STEP 1 Assigned approvers can navigate to ","type":"text"},{"marks":[{"type":"bold"}],"text":"Workflow > Received Requests > To Do","type":"text"},{"text":" to view pending requests.","type":"text"}],"type":"paragraph"},{"content":[{"text":"STEP 2 Open the details page for the request and click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Approve","type":"text"},{"text":" button to complete the approval process.","type":"text"}],"type":"paragraph"},{"attrs":{"level":1},"content":[{"text":"Executing an Approved SQL Request","type":"text"}],"type":"heading"},{"content":[{"text":"STEP 1 The requester can go to ","type":"text"},{"marks":[{"type":"bold"}],"text":"Workflow > Executions > To Do","type":"text"},{"text":" to view pending executions.","type":"text"}],"type":"paragraph"},{"content":[{"text":"STEP 2 Open the request, review its details, and click the Execute button in the top-right corner to run the query.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"To cancel the execution, click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Cancel","type":"text"},{"text":" button instead.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Once the execution is complete, check the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Results","type":"text"},{"text":" tab in the request details page to see whether the execution was successful or failed.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"You can also view a history of executed requests under ","type":"text"},{"marks":[{"type":"bold"}],"text":"Workflow > Executions > Done.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"}],"type":"doc"}