.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"When assigning to ","type":"text"},{"marks":[{"type":"bold"}],"text":"Group","type":"text"},{"text":", leave the ","type":"text"},{"marks":[{"type":"bold"}],"text":"loginId","type":"text"},{"text":" field blank and click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Save and Go Back","type":"text"},{"text":" button.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 4 Setting Up QueryPie Application Integration Information in Okta.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"Go to the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Applications > Applications","type":"text"},{"text":" menu and then go to the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Sign On","type":"text"},{"text":" tab.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"In the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Settings","type":"text"},{"text":" area, click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Edit","type":"text"},{"text":" button, enter the domain address where QueryPie is installed in the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Base URL","type":"text"},{"text":" field, and save it.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"orderedList"}],"type":"doc"}