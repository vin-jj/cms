{"content":[{"attrs":{"src":"https://www.youtube.com/embed/HPH5vSu99v8?si=iHV-kg68_0Yl2v_O"},"type":"youtube"},{"attrs":{"level":1},"content":[{"text":"Overview","type":"text"}],"type":"heading"},{"content":[{"text":"QueryPie supports Okta integration, allowing you to synchronize users and groups from Okta to grant access and enforce policies. This integration provides a streamlined and convenient experience for your users while maintaining strict security policies. By integrating with Okta, QueryPie enhances the security, operational efficiency, and user experience of your databases and systems management ecosystem.","type":"text"}],"type":"paragraph"},{"attrs":{"level":1},"content":[{"text":"Setting Up Okta Integration and Synchronization in QueryPie","type":"text"}],"type":"heading"},{"content":[{"text":"STEP 1 In QueryPie, go to ","type":"text"},{"marks":[{"type":"bold"}],"text":"Administrator > General > User Management > Authentication.","type":"text"}],"type":"paragraph"},{"content":[{"text":"STEP 2 Enter the following information.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Type:","type":"text"},{"text":" Okta","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Identity Provider Metadata:","type":"text"},{"text":" Access the URL specified in the Metadata URL in a separate tab, copy the displayed XML information, and paste it here.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 3 If you want to set up automatic synchronization, check ","type":"text"},{"marks":[{"type":"bold"}],"text":"\"Use Synchronization with the Authentication System\"","type":"text"},{"text":" and enter the following details.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"API URL:","type":"text"},{"text":" Click your profile in the top right corner of the Okta admin page to find the URL in the format ","type":"text"},{"marks":[{"type":"code"}],"text":"{domain}.okta.com","type":"text"},{"text":".","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"API Token:","type":"text"},{"text":" Enter the Okta Admin API token.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Application ID:","type":"text"},{"text":" Enter this only if you use more than one QueryPie App in Okta.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Go to Okta ","type":"text"},{"marks":[{"type":"bold"}],"text":"Admin > Applications","type":"text"},{"text":", and check the URL in the top bar, where the Application ID is displayed (as shown in the provided screenshot).","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 4 Configure the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Scheduling","type":"text"},{"text":" option under the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Replication Frequency","type":"text"},{"text":" field.","type":"text"}],"type":"paragraph"},{"content":[{"text":"STEP 5 Click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Dry Run","type":"text"},{"text":" button to verify that the integration details have been entered correctly, and then click ","type":"text"},{"marks":[{"type":"code"}],"text":"Save Changes","type":"text"},{"text":" to save.","type":"text"}],"type":"paragraph"},{"content":[{"text":"STEP 6 Finally, click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Synchronize","type":"text"},{"text":" button to sync users from Okta.","type":"text"}],"type":"paragraph"},{"attrs":{"level":1},"content":[{"text":"Preparation for Okta Integration","type":"text"}],"type":"heading"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Before registering Okta in QueryPie, you must first register QueryPie in the Okta service.","type":"text"},{"text":" (This step is required only once.)","type":"text"}],"type":"paragraph"}],"type":"blockquote"},{"content":[{"text":"STEP 1 Adding QueryPie as an Application in Okta.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"Log in to the Okta admin console using an administrator account.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Go to ","type":"text"},{"marks":[{"type":"bold"}],"text":"Applications > Applications","type":"text"},{"text":", click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Browse App Catalog","type":"text"},{"text":" button, and search for ","type":"text"},{"marks":[{"type":"bold"}],"text":"QueryPie","type":"text"},{"text":".","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"On the QueryPie application page, click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Add Integration","type":"text"},{"text":" button.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Confirm that ","type":"text"},{"marks":[{"type":"bold"}],"text":"QueryPie","type":"text"},{"text":" is entered in ","type":"text"},{"marks":[{"type":"bold"}],"text":"the Application Label","type":"text"},{"text":" field, then click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Done","type":"text"},{"text":" button to add the application.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"orderedList"},{"content":[{"text":"STEP 2 Setting Up a Profile Editor.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"Go to ","type":"text"},{"marks":[{"type":"bold"}],"text":"Directory > Profile Editor","type":"text"},{"text":" and click on ","type":"text"},{"marks":[{"type":"bold"}],"text":"QueryPie User","type":"text"},{"text":" from the list of profiles.","type":"text"}],"type":"paragraph"}],"type":