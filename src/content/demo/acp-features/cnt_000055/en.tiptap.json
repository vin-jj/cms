{"content":[{"attrs":{"src":"https://www.youtube.com/embed/H_SRKmBlvS4?si=50W5_kdMiOf9DKn5"},"type":"youtube"},{"attrs":{"level":1},"content":[{"text":"Overview","type":"text"}],"type":"heading"},{"content":[{"text":"You can view logs related to Database Access Control in the Databases section of QueryPie Audit. This includes information on granted and revoked DB access permissions, DB access history, executed queries, and DML query snapshots. Additionally, you can check and release connection lock records due to password failures or prolonged inactivity.","type":"text"}],"type":"paragraph"},{"attrs":{"level":1},"content":[{"text":"Logs provided by QueryPie DAC","type":"text"}],"type":"heading"},{"attrs":{"level":2},"content":[{"text":"DB Access History","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"text":"This section records the history of ","type":"text"},{"marks":[{"type":"bold"}],"text":"DB connection attempts and disconnections.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":2},"content":[{"text":"Query Audit","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"text":"QueryPie records the history of executed ","type":"text"},{"marks":[{"type":"bold"}],"text":"queries and actions performed","type":"text"},{"text":" on the database.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":2},"content":[{"text":"Running Queries","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"text":"You can view currently running queries in QueryPie. Once a query execution is completed, the details are recorded in the Query Audit log.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":2},"content":[{"text":"DML Snapshots","type":"text"}],"type":"heading"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Precondition:","type":"text"},{"text":" These snapshots are saved if the DML Snapshot setting is enabled for each DB connection.","type":"text"}],"type":"paragraph"}],"type":"blockquote"},{"content":[{"content":[{"content":[{"text":"QueryPie records pre- and post-data snapshots when ","type":"text"},{"marks":[{"type":"bold"}],"text":"INSERT, UPDATE, or DELETE queries","type":"text"},{"text":" are executed.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":2},"content":[{"text":"Account Lock History","type":"text"}],"type":"heading"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Precondition:","type":"text"},{"text":" It follows the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Maximum Login Failures","type":"text"},{"text":" and ","type":"text"},{"marks":[{"type":"bold"}],"text":"Specified Time Interval Before Lockout","type":"text"},{"text":" policies for the connection.","type":"text"}],"type":"paragraph"}],"type":"blockquote"},{"content":[{"content":[{"content":[{"text":"QueryPie displays ","type":"text"},{"marks":[{"type":"bold"}],"text":"connection lock history due to password failures","type":"text"},{"text":" and ","type":"text"},{"marks":[{"type":"bold"}],"text":"prolonged inactivity for each user.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"All failed connection attempts, such as incorrect password entries or attempts from unauthorized IPs, are counted. When the failed attempts reach the threshold set by the administrator, the connection account is locked.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":2},"content":[{"text":"Access Control Logs","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"text":"QueryPie records the history of ","type":"text"},{"marks":[{"type":"bold"}],"text":"granting and revoking access permissions","type":"text"},{"text":" to DB connections for users and groups.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"The granting and revocation of DB connection permissions are managed in the Access Control menu.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"}],"type":"doc"}