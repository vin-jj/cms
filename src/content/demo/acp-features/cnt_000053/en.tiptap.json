{"content":[{"attrs":{"src":"https://www.youtube.com/embed/k04sppmIr50?si=C5pxwOPPxRVhvoeA"},"type":"youtube"},{"attrs":{"level":1},"content":[{"text":"Overview","type":"text"}],"type":"heading"},{"content":[{"text":"This tutorial explains how to synchronize Kubernetes clusters using the cloud synchronization feature or manually register clusters for management.","type":"text"}],"type":"paragraph"},{"attrs":{"level":1},"content":[{"text":"Synchronizing Kubernetes Resources via AWS Integration","type":"text"}],"type":"heading"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Preconditions","type":"text"},{"text":" 1. ","type":"text"},{"marks":[{"type":"bold"}],"text":"To synchronize Kubernetes resources, ensure the following policies are assigned:","type":"text"},{"text":" - eks:ListClusters - eks:DescribeCluster - eks:ListAccessEntries - eks:DescribeAccessEntry - eks:CreateAccessEntry - eks:ListAssociatedAccessPolicies - eks:AssociateAccessPolicy 2. Additionally, update the ","type":"text"},{"marks":[{"type":"bold"}],"text":"AWS EKS Authentication Mode:","type":"text"},{"text":" - Synchronization uses the EKS access entry API. To ensure smooth synchronization, it’s recommended to set the authentication mode to ","type":"text"},{"marks":[{"type":"bold"}],"text":"EKS API and ConfigMap.","type":"text"}],"type":"paragraph"}],"type":"blockquote"},{"content":[{"text":"STEP 1 In the Cloud Provider menu, click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Create Provider","type":"text"},{"text":" button and enter the following details:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Name:","type":"text"},{"text":" A unique name to identify the provider","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Cloud Provider:","type":"text"},{"text":" Amazon Web Services","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Region:","type":"text"},{"text":" The region of the resources to be synchronized","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Credential","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Default Credential:","type":"text"},{"text":" Assign IAM policies to the EC2 instance where QueryPie is installed to synchronize resources within the same AWS account","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Cross Account Role:","type":"text"},{"text":" Create an IAM role to synchronize resources from another AWS account","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Search Filter:","type":"text"},{"text":" Filter specific types of resources to synchronize","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"It works the same way as AWS's search mechanism.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"You can use filters such as name, host, OS, and tags. Enter the filters in the following order:","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"marks":[{"type":"code"}],"text":"Key -> Press Enter -> Select a search condition -> Press Enter -> Enter the value -> Press Enter","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Replication Frequency:","type":"text"},{"text":" Method of synchronization","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Manual:","type":"text"},{"text":" Synchronize only when manually triggered","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Scheduling:","type":"text"},{"text":" Synchronize periodically using a schedule. Cron Expressions are supported.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 2 Select the provider you created in the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Cloud Provider","type":"text"},{"text":" menu.","type":"text"}],"type":"paragraph"},{"content":[{"text":"STEP 3 Click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Synchronize","type":"text"},{"text":" button to sync AWS resources.","type":"text"}],"type":"paragraph"},{"content":[{"text":"STEP 4 Go to the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Clusters","type":"text"},{"text":" menu to view the synchronized resources.","type":"text"}],"type":"paragraph"},{"attrs":{"level":1},"content":[{"text":"Manually Registering a Kubernetes Cluster","type":"text"}],"type":"heading"},{"content":[{"text":"STEP 1 In the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Clusters","type":"text"},{"text":" menu, click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Create Cluster","type":"text"},{"text":" button and enter the following details:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Name:","type":"text"},{"text":" A unique name to identify the cluster","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Version:","type":"text"},{"text":" Detailed version information for the cluster","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"API URL:","type":"text"},{"text":" The API URL of the Kubernetes cluster to receive API requests","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 2 Click the ","type":"text"},{"marks":[{"type":"bold"}],"text":"download and run this script","type":"text"},{"text":" button to download the script.","type":"text"}],"type":"paragraph"},{"content":[{"text":"STEP 3 Run the downloaded script on the target cluster, and enter the following information from the script’s output:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Service Account Token:","type":"text"},{"text":" The Kubernetes service account token used by QueryPie Proxy to make API calls","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Certificate Authority:","type":"text"},{"text":" The CA certificate used by QueryPie to verify the Kubernetes API server","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 4 Click ","type":"text"},{"marks":[{"type":"code"}],"text":"Verify Credential","type":"text"},{"text":" to ensure the connection is valid.","type":"text"}],"type":"paragraph"},{"content":[{"text":"STEP 5 Configure the logging options for the cluster:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Request Audit:","type":"text"},{"text":" Enable logging of Kubernetes API call history for the cluster","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Request Audit Types:","type":"text"},{"text":" Select the types of API verbs to be logged","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Pod Session Recording:","type":"text"},{"text":" Enable recording of sessions opened via ","type":"text"},{"marks":[{"type":"code"}],"text":"Pod exec","type":"text"},{"text":" commands within the cluster","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"To enable this option, ","type":"text"},{"marks":[{"type":"bold"}],"text":"Request Audit","type":"text"},{"text":" must be turned on, and the ","type":"text"},{"marks":[{"type":"code"}],"text":"create","type":"text"},{"text":" and ","type":"text"},{"marks":[{"type":"code"}],"text":"get","type":"text"},{"text":" verbs must be selected under ","type":"text"},{"marks":[{"type":"bold"}],"text":"Request Audit Types","type":"text"},{"text":".","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 6 Click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Save","type":"text"},{"text":" button to successfully register the cluster.","type":"text"}],"type":"paragraph"}],"type":"doc"}