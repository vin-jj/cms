{"content":[{"attrs":{"src":"https://www.youtube.com/embed/yrGb8C7ltf4?si=UEHztCB_Iz8OTQXh"},"type":"youtube"},{"attrs":{"level":1},"content":[{"text":"Overview","type":"text"}],"type":"heading"},{"content":[{"text":"QueryPie offers a web SQL editor that allows users to execute queries and retrieve data directly through a web browser. The QueryPie Web SQL Editor enables users to quickly and easily access authorized connections after logging in.","type":"text"}],"type":"paragraph"},{"attrs":{"level":1},"content":[{"text":"Access DB via Web SQL Editor","type":"text"}],"type":"heading"},{"content":[{"text":"STEP 1 After logging in to QueryPie, click ","type":"text"},{"marks":[{"type":"code"}],"text":"Database","type":"text"},{"text":" on the top navigation bar.","type":"text"}],"type":"paragraph"},{"content":[{"text":"STEP 2 Select a ","type":"text"},{"marks":[{"type":"bold"}],"text":"DB Connection","type":"text"},{"text":" and click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Connect","type":"text"},{"text":" button on the right to establish a connection.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"The left panel displays all accessible DB connections.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Click the desired connection to view its details on the right panel.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":1},"content":[{"text":"Panel Descriptions","type":"text"}],"type":"heading"},{"content":[{"text":"The web editor consists of the left ","type":"text"},{"marks":[{"type":"bold"}],"text":"Object Panel","type":"text"},{"text":", ","type":"text"},{"marks":[{"type":"bold"}],"text":"top Toolbar","type":"text"},{"text":", central ","type":"text"},{"marks":[{"type":"bold"}],"text":"SQL Editor","type":"text"},{"text":", and right ","type":"text"},{"marks":[{"type":"bold"}],"text":"Object Info","type":"text"},{"text":" Panel.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"code"}],"text":"Change connection","type":"text"},{"text":" : Use the arrow button in the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Object Panel","type":"text"},{"text":" to view or switch between active connections.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"code"}],"text":"Disconnect","type":"text"},{"text":" : Click the disconnect button to terminate the current connection.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Change database:","type":"text"},{"text":" Change the currently connected database.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"※ Default database is connected initially.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Search object information:","type":"text"},{"text":" Search for schemas, tables, views, events, functions, procedures, and triggers in the database.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"View object information:","type":"text"},{"text":" View schemas, tables, views, events, functions, procedures, and triggers in the database.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Refresh object information:","type":"text"},{"text":" Click the ","type":"text"},{"marks":[{"type":"code"}],"text":"refresh","type":"text"},{"text":" button on the right when an object is selected to update the object information. (For individual objects, right-click and click ","type":"text"},{"marks":[{"type":"code"}],"text":"Reload Object","type":"text"},{"text":" button to refresh.)","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"code"}],"text":"Run SQL","type":"text"},{"text":" : Execute the written query. By default, the entire written query is executed.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"code"}],"text":"Stop","type":"text"},{"text":" : Stop the currently executing query.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"code"}],"text":"Object Panel","type":"text"},{"text":" : Option to toggle the left object panel.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"code"}],"text":"Open","type":"text"},{"text":" : Load an SQL file.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"code"}],"text":"Undo","type":"text"},{"text":" : Undo actions within the query.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"code"}],"text":"Redo","type":"text"},{"text":" : Redo previously undone actions.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"code"}],"text":"Format","type":"text"},{"text":" : Format the written query.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"code"}],"text":"Import","type":"text"},{"text":" : Import data from SQL/CSV/Excel files and store it in the database.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"code"}],"text":"Export","type":"text"},{"text":" : Download data as SQL/CSV/JSON/Excel files.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"code"}],"text":"SQL Request","type":"text"},{"text":" : Send the query written in the editor to the SQL Request workflow page.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Supports autocomplete while writing queries, and you can use context menus and shortcuts.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"code"}],"text":"Limit","type":"text"},{"text":" : Limit the number of rows output when executing a query (default is 1000).","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"code"}],"text":"Expand","type":"text"},{"text":" : View query execution results in full screen.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"code"}],"text":"Stack/Column View","type":"text"},{"text":" : View results in horizontally or vertically split grids when multiple queries are executed.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"code"}],"text":"Data","type":"text"},{"text":" : View data of table/view objects.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"code"}],"text":"Structure","type":"text"},{"text":" : View structure of table/view objects.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"code"}],"text":"Index","type":"text"},{"text":" : View index information of tables.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"code"}],"text":"Relation","type":"text"},{"text":" : View the relationship of tables.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"code"}],"text":"Trigger","type":"text"},{"text":" : View trigger information.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"code"}],"text":"Script","type":"text"},{"text":" : View script information of objects.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"code"}],"text":"Info","type":"text"},{"text":" : View detailed information of objects.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"}],"type":"doc"}