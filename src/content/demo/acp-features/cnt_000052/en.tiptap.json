{"content":[{"attrs":{"src":"https://www.youtube.com/embed/Yf8CymMZAGY?si=uvMzIc9FeLstyu-7"},"type":"youtube"},{"attrs":{"level":1},"content":[{"text":"Overview","type":"text"}],"type":"heading"},{"content":[{"text":"The cloud synchronization feature enables you to synchronize databases from multiple cloud platforms at once or manually register them. This tutorial provides instructions for syncing AWS resources to register them in QueryPie and for manually registering on-premises databases.","type":"text"}],"type":"paragraph"},{"attrs":{"level":1},"content":[{"text":"Syncing and Managing Databases via AWS Integration","type":"text"}],"type":"heading"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Precondition:","type":"text"},{"text":" Specific policies are required for database synchronization - ","type":"text"},{"marks":[{"type":"bold"}],"text":"RDS","type":"text"},{"text":" : AmazonRDSReadOnlyAccess - ","type":"text"},{"marks":[{"type":"bold"}],"text":"DynamoDB","type":"text"},{"text":" : AmazonDynamoDBFullAccess - ","type":"text"},{"marks":[{"type":"bold"}],"text":"Redshift","type":"text"},{"text":" : AmazonRedshiftReadOnlyAccess - ","type":"text"},{"marks":[{"type":"bold"}],"text":"Athena","type":"text"},{"text":" : AmazonAthenaFullAccess, AmazonS3DFullAccess - ","type":"text"},{"marks":[{"type":"bold"}],"text":"Redis","type":"text"},{"text":" : AmazonElastiCacheFullAccess","type":"text"}],"type":"paragraph"}],"type":"blockquote"},{"content":[{"text":"STEP 1 Navigate to the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Cloud Provider","type":"text"},{"text":" menu and click ","type":"text"},{"marks":[{"type":"code"}],"text":"Create Provider","type":"text"},{"text":". Enter the following details:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Name:","type":"text"},{"text":" A unique name to identify the provider.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Cloud Provider:","type":"text"},{"text":" Select \"Amazon Web Services.\"","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Region:","type":"text"},{"text":" Specify the region of the resources to synchronize.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Credential:","type":"text"},{"text":" Choose one of the following options:","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Default Credential:","type":"text"},{"text":" Assign a policy to the IAM role of the EC2 instance where QueryPie is installed to synchronize resources within the same AWS account.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Cross Account Role:","type":"text"},{"text":" Create an IAM role to synchronize resources from another AWS account.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Access Key:","type":"text"},{"text":" Enter the AWS account's access key to synchronize resources.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Database Type Filter:","type":"text"},{"text":" Specify the resource types to synchronize.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Replication Frequency:","type":"text"},{"text":" Choose the synchronization method:","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Manual:","type":"text"},{"text":" Synchronize resources only when initiated manually.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Scheduling:","type":