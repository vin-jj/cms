{"content":[{"attrs":{"src":"https://www.youtube.com/embed/5sHErWERHsw?si=fdW4n-V15fc7kA-Z"},"type":"youtube"},{"attrs":{"level":1},"content":[{"text":"Overview","type":"text"}],"type":"heading"},{"content":[{"text":"In an organization, sensitive data like personal or confidential information can be protected by configuring policies that mask such data upon retrieval. Using the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Data Masking","type":"text"},{"text":" menu, you can create and manage policies by selecting the target connection and defining rules to apply masking patterns to specific columns.","type":"text"}],"type":"paragraph"},{"attrs":{"level":1},"content":[{"text":"Creating a Data Masking Policy","type":"text"}],"type":"heading"},{"content":[{"text":"STEP 1 Navigate to the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Data Masking","type":"text"},{"text":" menu and click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Create Policy","type":"text"},{"text":" button. Enter the following details:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Policy Name:","type":"text"},{"text":" A unique name to identify the policy.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Target Connection:","type":"text"},{"text":" The database connection to which the policy will apply.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 2 After saving the policy, select the created policy and click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Add Rule List","type":"text"},{"text":" button to define rules. Provide the following details for each rule:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Database Name:","type":"text"},{"text":" Specify the database. This is required.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Table Name:","type":"text"},{"text":" Specify the table. This is required.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Column Name:","type":"text"},{"text":" Specify the column. This is required.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Masking Pattern:","type":"text"},{"text":" Add one or more masking patterns to be applied to the specified column.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Use the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Masking Pattern","type":"text"},{"text":" menu to create masking patterns via regular expressions. This menu also provides over 20 predefined patterns for masking personal and sensitive data.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Use the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Allowed Users","type":"text"},{"text":" field to specify users or groups exempt from the masking rule.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Users or groups added to ","type":"text"},{"marks":[{"type":"bold"}],"text":"Allowed Users","type":"text"},{"text":" will be able to view unmasked data for the specified columns.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"※ If a user who is not listed in ","type":"text"},{"marks":[{"type":"bold"}],"text":"Allowed Users","type":"text"},{"text":" queries data covered by a ","type":"text"},{"marks":[{"type":"bold"}],"text":"Data Masking Policy","type":"text"},{"text":", the data will appear masked based on the applied pattern.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"For example, email addresses might appear as ","type":"text"},{"marks":[{"type":"code"}],"text":"*****@gmail.com","type":"text"},{"text":" depending on the masking pattern applied.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"}],"type":"doc"}