{"content":[{"attrs":{"src":"https://www.youtube.com/embed/UGx2rh4Bp9A?si=Nd9osnoLYx6cooYZ"},"type":"youtube"},{"attrs":{"level":1},"content":[{"text":"Overview","type":"text"}],"type":"heading"},{"content":[{"text":"An Access Role Request allows you to conveniently request a role for the required server or Kubernetes cluster. Upon approval, the role is granted immediately, and you can access the servers or Kubernetes clusters permitted by the role.","type":"text"}],"type":"paragraph"},{"attrs":{"level":1},"content":[{"text":"Submitting a Role Access Request","type":"text"}],"type":"heading"},{"content":[{"text":"STEP 1 Access the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Role Access Request","type":"text"},{"text":" page through the following paths:","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"Workflow > Submit Request > Role Access Request","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 2 Select approval rules and assign approvers.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Approval Rule:","type":"text"},{"text":" Choose an approval rule from the list created by the administrator in ","type":"text"},{"marks":[{"type":"bold"}],"text":"General > Approval Rules","type":"text"},{"text":".","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Approval rules determine who must approve the request. If the rule specifies approvers, they will be automatically assigned.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Approver:","type":"text"},{"text":" Use the ","type":"text"},{"marks":[{"type":"code"}],"text":"+","type":"text"},{"text":" button to add approvers at each stage of the approval workflow.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"A single assignee can complete the approval request:","type":"text"},{"text":" Any one approver in a group can approve the request.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"All assignees must approve this request:","type":"text"},{"text":" All assigned approvers must approve the request for it to proceed.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 3 Select Target Role","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Service:","type":"text"},{"text":" Server Access Control","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Role:","type":"text"},{"text":" Select the role from the list displayed.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"When selecting a Role, you can check the servers and accounts to which permissions are granted.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 4 After entering all details, click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Submit","type":"text"},{"text":" button to send the request for approval.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Title:","type":"text"},{"text":" Provide a title for the request.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Expiration Date:","type":"text"},{"text":" Specify the expiration date for the requested privileges (default: 1 year).","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Reason for Request:","type":"text"},{"text":" State the reason for requesting access.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":1},"content":[{"text":"Approving a Request","type":"text"}],"type":"heading"},{"content":[{"text":"STEP 1 Assigned approvers can navigate to ","type":"text"},{"marks":[{"type":"bold"}],"text":"Workflow > Received Requests > To Do","type":"text"},{"text":" to view pending requests.","type":"text"}],"type":"paragraph"},{"content":[{"text":"STEP 2 Open the details page for the request and click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Approve","type":"text"},{"text":" button to complete the approval process.","type":"text"}],"type":"paragraph"}],"type":"doc"}