{"content":[{"attrs":{"src":"https://www.youtube.com/embed/UGx2rh4Bp9A?si=Nd9osnoLYx6cooYZ"},"type":"youtube"},{"attrs":{"level":1},"content":[{"text":"Overview","type":"text"}],"type":"heading"},{"content":[{"text":"Access Role Request는 접근이 필요한 서버에 대해 역할(Role)을 간편하게 요청할 수 있습니다. 승인 즉시 역할이 부여되며, 역할에서 허용하는 서버에 접속할 수 있습니다.","type":"text"}],"type":"paragraph"},{"attrs":{"level":1},"content":[{"text":"역할 기반의 권한 요청하기","type":"text"}],"type":"heading"},{"content":[{"text":"STEP 1 아래 경로를 통해 ","type":"text"},{"marks":[{"type":"bold"}],"text":"Role Access Request","type":"text"},{"text":" 페이지에 진입합니다.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"text":"Workflow > Submit Request > Role Access Request","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 2 결재 규칙을 선택하고 승인자를 지정합니다.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Approval Rule:","type":"text"},{"text":" ","type":"text"},{"marks":[{"type":"bold"}],"text":"General > Approval Rules","type":"text"},{"text":" 메뉴에서 관리자가 생성한 규칙 목록들이 나타납니다.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"규칙에 따라 승인 대상이 달라질 수 있으며, 관리자가 승인자를 지정한 결재 규칙인 경우 자동으로 승인자가 지정됩니다.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Approver:","type":"text"},{"text":" 결재 라인에서 ","type":"text"},{"marks":[{"type":"code"}],"text":"+","type":"text"},{"text":" 버튼을 누르고 단계별 승인자를 지정합니다.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"A single assignee can complete the approval request:","type":"text"},{"text":" 여러 명 중 한 명의 승인만으로 결재 요청이 승인 처리됩니다.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"All assignees must approve this request:","type":"text"},{"text":" 모든 승인자가 승인하여야 결재 요청이 승인 처리됩니다.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 3 요청 대상 역할을 선택합니다.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Service:","type":"text"},{"text":" Server Access Control","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Role:","type":"text"},{"text":" 표시되는 역할 목록에서 요청할 역할을 선택합니다.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"Role 선택 시, 권한이 부여되는 서버와 계정을 확인할 수 있습니다.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 4 요청 정보를 입력한 후 ","type":"text"},{"marks":[{"type":"code"}],"text":"Submit","type":"text"},{"text":" 버튼을 눌러 Request를 요청합니다.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Title:","type":"text"},{"text":" 요청 제목을 입력합니다.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Expiration Date:","type":"text"},{"text":" 해당 권한이 회수되는 만료일자를 선택합니다.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Reason for Request:","type":"text"},{"text":" 권한을 요청하는 사유를 입력합니다.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":1},"content":[{"text":"요청받은 결재 승인하기","type":"text"}],"type":"heading"},{"content":[{"text":"STEP 1 승인자로 지정된 관리자는 ","type":"text"},{"marks":[{"type":"bold"}],"text":"Workflow > Received Requests > To Do","type":"text"},{"text":" 메뉴로 이동합니다.","type":"text"}],"type":"paragraph"},{"content":[{"text":"STEP 2 결재의 디테일 페이지에서 ","type":"text"},{"marks":[{"type":"code"}],"text":"Approve","type":"text"},{"text":" 버튼을 눌러 승인처리합니다.","type":"text"}],"type":"paragraph"}],"type":"doc"}