{"content":[{"attrs":{"src":"https://www.youtube.com/embed/4uikq_8mS9s?si=NvF1VmtHenOPXaqk"},"type":"youtube"},{"attrs":{"level":1},"content":[{"text":"Overview","type":"text"}],"type":"heading"},{"content":[{"text":"To maintain a high level of database access control and security, QueryPie provides versatile access control mechanisms based on roles and attributes. Only authenticated users can access databases granted through QueryPie, and SQL execution is restricted to predefined query combinations.","type":"text"}],"type":"paragraph"},{"attrs":{"level":1},"content":[{"text":"Granting Access Control Privileges","type":"text"}],"type":"heading"},{"content":[{"text":"STEP 1 Navigate to the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Privilege","type":"text"},{"text":" menu and click the ","type":"text"},{"marks":[{"type":"code"}],"text":"Create Privilege Type","type":"text"},{"text":" button to create a new privilege.","type":"text"}],"type":"paragraph"},{"content":[{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Name:","type":"text"},{"text":" Assign a unique name to identify the privilege.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Database Type:","type":"text"},{"text":" Specify the database type. Options include ","type":"text"},{"marks":[{"type":"bold"}],"text":"General","type":"text"},{"text":" and ","type":"text"},{"marks":[{"type":"bold"}],"text":"Redis","type":"text"},{"text":", depending on the query properties.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Privilege Type:","type":"text"},{"text":" Define the queries allowed under this privilege.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"marks":[{"type":"bold"}],"text":"Functions:","type":"text"},{"text":" Choose the operations that can be performed under this privilege.","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"These settings control functionalities within the QueryPie Web Editor.","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"content":[{"text":"STEP 2 Go to the ","type":"text"},{"marks":[{"type":"bold"}],"text":"Access Control","type":"text"},{"text":" menu and select the user or group to whom you want to grant the privilege.","type":"text"}],"type":"paragraph"},{"content":[{"text":"STEP 3 Identify the target connection and apply the relevant privilege.","type":"text"}],"type":"paragraph"}],"type":"doc"}