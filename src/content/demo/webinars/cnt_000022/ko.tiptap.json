{"content":[{"attrs":{"alt":"","caption":"","src":"/demo/webinars/air-company-mcp.webp"},"type":"image"},{"attrs":{"level":2},"content":[{"text":"【7/3（木）開催】ウェビナー「「MCP」の基礎がわかる”超”入門講座 」","type":"text"}],"type":"heading"},{"content":[{"text":"AIが世界を動かす時代が、いよいよ現実に。","type":"text"},{"type":"hardBreak"},{"text":"その中心にあるのが、革新的なプロトコル「MCP」です。","type":"text"},{"type":"hardBreak"},{"text":"従来の常識を覆し、AI活用を一気に加速させました。","type":"text"}],"type":"paragraph"},{"content":[{"text":"今こそ、AI時代の必須スキル「MCP」を、しっかり学んでみませんか？","type":"text"}],"type":"paragraph"},{"content":[{"text":"生成AI / MCPをフル活用し、自律型セキュリティ運用を実現する","type":"text"},{"type":"hardBreak"},{"text":"「QueryPie Secure Enterprise AI Hub」の最新情報をお届けします。","type":"text"}],"type":"paragraph"},{"attrs":{"level":2},"content":[{"text":"【ウェビナー概要】","type":"text"}],"type":"heading"},{"content":[{"content":[{"content":[{"text":"日時：2025年7月3日（木）13:00～13:45","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"形式：Zoomによるオンライン開催","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"参加費：無料（事前登録制）","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"主催：AIR Company Limited","type":"text"}],"type":"paragraph"}],"type":"listItem"},{"content":[{"content":[{"text":"共催：QueryPie","type":"text"}],"type":"paragraph"}],"type":"listItem"}],"type":"bulletList"},{"attrs":{"level":2},"content":[{"text":"【参加者特典】","type":"text"}],"type":"heading"},{"content":[{"text":"QueryPie導入事例レポート（導入企業様名、実際のシステム構成図など）","type":"text"}],"type":"paragraph"},{"attrs":{"level":2},"content":[{"text":"【講師】","type":"text"}],"type":"heading"},{"content":[{"text":"高橋 良汰（AIR社 データソリューション事業部）","type":"text"}],"type":"paragraph"},{"attrs":{"level":2},"content":[{"text":"【詳細・お申し込みはこちら】","type":"text"}],"type":"heading"},{"content":[{"marks":[{"attrs":{"href":"https://air.co.jp/cat_02/12778/"},"type":"link"}],"text":"https://air.co.jp/cat_02/12778/","type":"text"}],"type":"paragraph"}],"type":